@model List<PostexS.Models.Domain.EmployeeMoneyTransferRequest>
@{
    var user = ViewBag.User as PostexS.Models.Domain.ApplicationUser;
    ViewData["Title"] = $"تاريخ تحويلات: {user?.Name ?? "—"}";

    double totalApproved = Model?.Where(x => x.Status == PostexS.Models.Enums.TransferRequestStatus.Approved)
                                  .Sum(x => x.ApprovedAmount ?? 0) ?? 0;
    double totalRequested = Model?.Sum(x => x.RequestedAmount) ?? 0;
    int discCount = Model?.Count(x => x.HasDiscrepancy) ?? 0;
    int approvedCount = Model?.Count(x => x.Status == PostexS.Models.Enums.TransferRequestStatus.Approved) ?? 0;
}

@Html.Partial("_Shared")

<div class="et-page">
    <div class="et-hero purple">
        <div>
            <h1><i class="fa fa-user-circle"></i> @ViewData["Title"]</h1>
            <p>كل التحويلات اللي قدّمها هذا الموظف — حالة، مبالغ، وفروقات.</p>
        </div>
        <a href="javascript:history.back()" class="et-btn" style="background:#fff; color:#6d28d9;">
            <i class="fa fa-arrow-right"></i> رجوع
        </a>
    </div>

    <!-- Stats -->
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 14px; margin-bottom: 18px;">
        <div class="et-card" style="margin: 0; padding: 18px; display:flex; align-items:center; gap:12px;">
            <div style="width:46px; height:46px; border-radius:12px; background:linear-gradient(135deg,#a78bfa,#7c3aed); color:#fff; display:grid; place-items:center; font-size:20px;"><i class="fa fa-list"></i></div>
            <div><div style="font-size:11px; color:#64748b; font-weight:600;">إجمالي الطلبات</div><div style="font-size:22px; font-weight:800; color:#0f172a;">@(Model?.Count ?? 0)</div></div>
        </div>
        <div class="et-card" style="margin: 0; padding: 18px; display:flex; align-items:center; gap:12px;">
            <div style="width:46px; height:46px; border-radius:12px; background:linear-gradient(135deg,#34d399,#059669); color:#fff; display:grid; place-items:center; font-size:20px;"><i class="fa fa-check"></i></div>
            <div><div style="font-size:11px; color:#64748b; font-weight:600;">مقبولة</div><div style="font-size:22px; font-weight:800; color:#0f172a;">@approvedCount</div></div>
        </div>
        <div class="et-card" style="margin: 0; padding: 18px; display:flex; align-items:center; gap:12px;">
            <div style="width:46px; height:46px; border-radius:12px; background:linear-gradient(135deg,#10b981,#047857); color:#fff; display:grid; place-items:center; font-size:20px;"><i class="fa fa-money"></i></div>
            <div><div style="font-size:11px; color:#64748b; font-weight:600;">إجمالي المُعتمد</div><div style="font-size:20px; font-weight:800; color:#16a34a;">@totalApproved.ToString("N2") <small style="font-size:11px;">جنيه</small></div></div>
        </div>
        <div class="et-card" style="margin: 0; padding: 18px; display:flex; align-items:center; gap:12px;">
            <div style="width:46px; height:46px; border-radius:12px; background:linear-gradient(135deg,#fbbf24,#d97706); color:#fff; display:grid; place-items:center; font-size:20px;"><i class="fa fa-exclamation-triangle"></i></div>
            <div><div style="font-size:11px; color:#64748b; font-weight:600;">طلبات بفروقات</div><div style="font-size:22px; font-weight:800; color:#0f172a;">@discCount</div></div>
        </div>
    </div>

    <div class="et-card">
        <h3>
            <i class="fa fa-history" style="color:#8b5cf6;"></i> سجل التحويلات
            @if (user != null) { <span style="font-size:13px; color:#64748b; font-weight:600;">— @user.UserName</span> }
        </h3>

        @if (Model == null || Model.Count == 0)
        {
            <div class="et-empty">
                <i class="fa fa-inbox"></i>
                <strong>لا توجد تحويلات</strong>
                هذا المستخدم لم يقدّم أي طلبات تحويل.
            </div>
        }
        else
        {
            <div style="overflow-x:auto;">
                <table class="et-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>المُقدَّم</th>
                            <th>المُعتمد</th>
                            <th>الحالة</th>
                            <th>تاريخ التقديم</th>
                            <th>تاريخ المعالجة</th>
                            <th>ملاحظات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            var statusCls = item.Status == PostexS.Models.Enums.TransferRequestStatus.Pending ? "pending"
                                          : item.Status == PostexS.Models.Enums.TransferRequestStatus.Approved ? "approved" : "rejected";
                            var statusText = item.Status == PostexS.Models.Enums.TransferRequestStatus.Pending ? "معلق"
                                           : item.Status == PostexS.Models.Enums.TransferRequestStatus.Approved ? "مقبول" : "مرفوض";
                            <tr>
                                <td><strong>#@item.Id</strong></td>
                                <td><span class="et-amount">@item.RequestedAmount.ToString("0.##")</span></td>
                                <td>
                                    @if (item.ApprovedAmount.HasValue)
                                    {
                                        <span class="et-amount @(item.HasDiscrepancy ? "out" : "in")">@item.ApprovedAmount.Value.ToString("0.##")</span>
                                        @if (item.HasDiscrepancy) { <div><span class="et-disc-badge"><i class="fa fa-exclamation-triangle"></i> فرق</span></div> }
                                    }
                                    else { <span style="color:#cbd5e1;">—</span> }
                                </td>
                                <td><span class="et-badge @statusCls"><span class="dot"></span> @statusText</span></td>
                                <td>@item.CreateOn.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                                <td>@(item.ProcessedAt?.ToLocalTime().ToString("yyyy-MM-dd HH:mm") ?? "—")</td>
                                <td style="max-width:280px; font-size:12px;">
                                    @if (!string.IsNullOrEmpty(item.EmployeeNotes)) { <div><strong>موظف:</strong> @item.EmployeeNotes</div> }
                                    @if (!string.IsNullOrEmpty(item.AdminNotes))    { <div class="et-meta" style="margin-top:3px;"><strong>أدمن:</strong> @item.AdminNotes</div> }
                                    @if (item.HasDiscrepancy && !string.IsNullOrEmpty(item.DiscrepancyNote))
                                    {
                                        <div style="margin-top:4px; font-size:11px; color:#78350f; background:#fef3c7; padding:5px 7px; border-radius:5px;"><i class="fa fa-info-circle"></i> @item.DiscrepancyNote</div>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
