@*
   ملف مشترك للستايلات والـ helpers بين صفحات تحويلات الموظفين.
   يتم تضمينه عن طريق Html.Partial("_Shared")
*@
<style>
    .et-page { font-family: 'Cairo', 'Tajawal', sans-serif; padding: 24px; background: #f5f7fb; min-height: 100vh; }

    .et-hero {
        color: #fff; padding: 26px 32px; border-radius: 18px;
        display: flex; justify-content: space-between; align-items: center;
        flex-wrap: wrap; gap: 16px; margin-bottom: 22px;
        box-shadow: 0 14px 36px -14px rgba(0,0,0,.25);
    }
    .et-hero.green  { background: linear-gradient(135deg, #10b981 0%, #047857 100%); }
    .et-hero.blue   { background: linear-gradient(135deg, #3b82f6 0%, #1d4ed8 100%); }
    .et-hero.amber  { background: linear-gradient(135deg, #f59e0b 0%, #b45309 100%); }
    .et-hero.purple { background: linear-gradient(135deg, #8b5cf6 0%, #6d28d9 100%); }
    .et-hero h1 { margin: 0; font-size: 22px; font-weight: 800; display: flex; align-items: center; gap: 12px; }
    .et-hero p  { margin: 6px 0 0; opacity: .92; font-size: 13.5px; max-width: 720px; line-height: 1.7; }

    .et-card {
        background: #fff; border-radius: 16px; padding: 24px;
        box-shadow: 0 4px 22px -10px rgba(15,23,42,.12);
        border: 1px solid #eef0f5; margin-bottom: 18px;
    }
    .et-card h3 { margin: 0 0 16px; font-size: 17px; font-weight: 700; color: #0f172a; display: flex; align-items: center; gap: 10px; }

    .et-form-row { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 18px; margin-bottom: 16px; }
    .et-field label { display: block; font-size: 13px; font-weight: 700; color: #334155; margin-bottom: 8px; }
    .et-field label .req { color: #ef4444; margin-right: 3px; }
    .et-field .form-control {
        width: 100%; padding: 12px 14px; border-radius: 10px;
        border: 1.5px solid #e2e8f0; background: #fff; font-size: 14px;
        transition: all .2s; font-family: inherit;
    }
    .et-field .form-control:focus { outline: none; border-color: #10b981; box-shadow: 0 0 0 4px rgba(16,185,129,.12); }
    .et-field .hint { font-size: 12px; color: #94a3b8; margin-top: 6px; line-height: 1.6; }

    .et-btn {
        display: inline-flex; align-items: center; gap: 8px; padding: 11px 22px;
        border-radius: 10px; font-size: 14px; font-weight: 700; border: none;
        cursor: pointer; transition: all .25s; text-decoration: none;
    }
    .et-btn:hover { transform: translateY(-2px); }
    .et-btn-primary { background: linear-gradient(135deg, #10b981, #047857); color: #fff; box-shadow: 0 6px 18px -8px rgba(4,120,87,.5); }
    .et-btn-primary:hover { color: #fff; }
    .et-btn-cancel { background: #f1f5f9; color: #475569; }
    .et-btn-danger { background: linear-gradient(135deg, #ef4444, #b91c1c); color: #fff; }
    .et-btn-danger:hover { color:#fff; }
    .et-btn-warn { background: linear-gradient(135deg, #f59e0b, #b45309); color: #fff; }
    .et-btn-warn:hover { color:#fff; }
    .et-btn-sm { padding: 7px 14px; font-size: 12px; }

    .et-alert { padding: 14px 18px; border-radius: 12px; margin-bottom: 18px; font-weight: 600; display: flex; align-items: center; gap: 10px; }
    .et-alert-ok  { background: #dcfce7; color: #166534; border-right: 4px solid #16a34a; }
    .et-alert-err { background: #fee2e2; color: #991b1b; border-right: 4px solid #dc2626; }

    /* Status badges */
    .et-badge {
        display: inline-flex; align-items: center; gap: 6px; padding: 5px 12px;
        border-radius: 20px; font-size: 12px; font-weight: 700;
    }
    .et-badge .dot { width: 8px; height: 8px; border-radius: 50%; }
    .et-badge.pending  { background: #fef3c7; color: #92400e; }
    .et-badge.pending .dot  { background: #f59e0b; animation: pulse 1.5s infinite; }
    .et-badge.approved { background: #dcfce7; color: #166534; }
    .et-badge.approved .dot { background: #16a34a; }
    .et-badge.rejected { background: #fee2e2; color: #991b1b; }
    .et-badge.rejected .dot { background: #dc2626; }
    @@keyframes pulse { 0%,100%{opacity:1;} 50%{opacity:.45;} }

    .et-disc-badge {
        background: #fef3c7; color: #92400e; padding: 3px 10px; border-radius: 6px;
        font-size: 11px; font-weight: 700; display: inline-flex; align-items: center; gap: 4px;
    }

    /* Table */
    .et-table { width: 100%; border-collapse: separate; border-spacing: 0; }
    .et-table thead th {
        background: #f8fafc; color: #475569; font-weight: 700; font-size: 12.5px;
        padding: 14px; text-align: right; border-bottom: 2px solid #e2e8f0;
    }
    .et-table tbody td { padding: 14px; border-bottom: 1px solid #f1f5f9; vertical-align: middle; font-size: 13.5px; color: #334155; }
    .et-table tbody tr:hover { background: #fafbfd; }
    .et-table tbody tr:last-child td { border-bottom: none; }

    .et-amount { font-weight: 800; font-size: 15px; color: #0f172a; }
    .et-amount.in  { color: #16a34a; }
    .et-amount.out { color: #dc2626; }

    .et-meta { font-size: 11.5px; color: #94a3b8; margin-top: 2px; }

    .et-empty {
        text-align: center; padding: 50px 20px; color: #94a3b8;
        background: #f8fafc; border-radius: 12px;
    }
    .et-empty i { font-size: 42px; color: #cbd5e1; display: block; margin-bottom: 12px; }
    .et-empty strong { color: #475569; display: block; font-size: 16px; margin-bottom: 6px; }

    /* Modal */
    .et-modal-overlay {
        position: fixed; inset: 0; background: rgba(15,23,42,.55); z-index: 9000;
        display: none; align-items: center; justify-content: center; padding: 20px;
        backdrop-filter: blur(3px);
    }
    .et-modal-overlay.show { display: flex; animation: fadeIn .2s ease; }
    .et-modal {
        background: #fff; border-radius: 18px; padding: 0; max-width: 560px; width: 100%;
        box-shadow: 0 20px 60px -10px rgba(0,0,0,.4); overflow: hidden;
        animation: slideUp .25s ease;
    }
    .et-modal-head {
        padding: 18px 22px; color: #fff; display: flex; align-items: center; gap: 10px;
    }
    .et-modal-head.green { background: linear-gradient(135deg, #10b981, #047857); }
    .et-modal-head.red   { background: linear-gradient(135deg, #ef4444, #b91c1c); }
    .et-modal-head h3 { margin: 0; font-size: 16px; font-weight: 700; }
    .et-modal-body { padding: 22px; }
    .et-modal-footer { padding: 12px 22px 22px; display: flex; gap: 10px; justify-content: flex-end; }
    @@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
    @@keyframes slideUp { from { opacity: 0; transform: translateY(15px); } to { opacity: 1; transform: translateY(0); } }

    .info-line { display: flex; justify-content: space-between; padding: 8px 0; border-bottom: 1px solid #f1f5f9; font-size: 13px; }
    .info-line:last-of-type { border-bottom: none; }
    .info-line .k { color: #64748b; font-weight: 600; }
    .info-line .v { color: #0f172a; font-weight: 700; }
</style>
