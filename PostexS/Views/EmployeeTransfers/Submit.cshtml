@model PostexS.Models.Domain.EmployeeMoneyTransferRequest
@{
    ViewData["Title"] = "تحويل أموال للأدمن الرئيسي";
}

@Html.Partial("_Shared")

<div class="et-page">
    <div class="et-hero green">
        <div>
            <h1><i class="fa fa-paper-plane"></i> @ViewData["Title"]</h1>
            <p>اكتب المبلغ اللي هتسلمه للأدمن الرئيسي مع ملاحظاتك. الطلب هيفضل معلق لحد ما الأدمن يوافق ويحدد المبلغ الفعلي اللي استلمه.</p>
        </div>
        <a href="@Url.Action("MyRequests")" class="et-btn et-btn-cancel" style="background:#fff; color:#047857;">
            <i class="fa fa-list"></i> طلباتي
        </a>
    </div>

    @if (TempData["Success"] != null) { <div class="et-alert et-alert-ok"><i class="fa fa-check-circle"></i> @TempData["Success"]</div> }
    @if (TempData["Error"] != null)   { <div class="et-alert et-alert-err"><i class="fa fa-times-circle"></i> @TempData["Error"]</div> }

    <div class="et-card">
        <h3><i class="fa fa-edit" style="color:#10b981;"></i> بيانات التحويل</h3>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="et-alert et-alert-err">
                <i class="fa fa-exclamation-triangle"></i>
                @Html.ValidationSummary(false)
            </div>
        }

        @using (Html.BeginForm("Submit", "EmployeeTransfers", FormMethod.Post))
        {
            @Html.AntiForgeryToken()

            <div class="et-form-row">
                <div class="et-field">
                    <label>المبلغ المُرسَل (جنيه) <span class="req">*</span></label>
                    @Html.TextBoxFor(m => m.RequestedAmount, new { @class = "form-control", type = "number", step = "0.01", min = "0.01", placeholder = "1000" })
                    @Html.ValidationMessageFor(m => m.RequestedAmount, "", new { @class = "hint", style = "color:#ef4444;" })
                    <div class="hint">المبلغ اللي هتسلمه للأدمن الرئيسي. لن يتم خصم أي شيء حتى توافق إدارة الأدمن وتدخل المبلغ الفعلي المستلم.</div>
                </div>
            </div>

            <div class="et-field" style="margin-bottom: 18px;">
                <label>ملاحظات (سبب التحويل، تفاصيل، ...)</label>
                @Html.TextAreaFor(m => m.EmployeeNotes, new { @class = "form-control", rows = "4", placeholder = "اكتب أي تفاصيل تساعد الأدمن في فهم التحويل..." })
            </div>

            <div style="background: #fef3c7; border-right: 4px solid #f59e0b; padding: 14px 18px; border-radius: 12px; margin-bottom: 18px; color: #78350f; font-size: 13px; line-height: 1.7;">
                <i class="fa fa-info-circle" style="color: #f59e0b;"></i>
                <strong>ملاحظة:</strong>
                الطلب يبقى معلقاً ولن يتم خصم أي مبلغ من محفظتك حتى يوافق الأدمن الرئيسي. الأدمن قد يسجل مبلغاً مختلفاً لو فرق العد —
                وهذا المبلغ هو اللي هيتسجل فعلياً في محفظتك.
            </div>

            <div style="display: flex; gap: 10px; justify-content: flex-end;">
                <a href="@Url.Action("MyRequests")" class="et-btn et-btn-cancel"><i class="fa fa-times"></i> إلغاء</a>
                <button type="submit" class="et-btn et-btn-primary"><i class="fa fa-paper-plane"></i> تقديم الطلب</button>
            </div>
        }
    </div>
</div>
