@model List<PostexS.Models.Domain.EmployeeMoneyTransferRequest>
@{
    ViewData["Title"] = "كل تحويلات الموظفين";
    var statusFilter = ViewBag.Status as PostexS.Models.Enums.TransferRequestStatus?;

    double totalApproved = Model?.Where(x => x.Status == PostexS.Models.Enums.TransferRequestStatus.Approved)
                                  .Sum(x => x.ApprovedAmount ?? 0) ?? 0;
    int discCount = Model?.Count(x => x.HasDiscrepancy) ?? 0;
}

@Html.Partial("_Shared")

<div class="et-page">
    <div class="et-hero blue">
        <div>
            <h1><i class="fa fa-history"></i> @ViewData["Title"]</h1>
            <p>سجل كامل بكل طلبات التحويل من الموظفين، مع الإحصائيات والفلاتر.</p>
        </div>
        <a href="@Url.Action("Pending")" class="et-btn" style="background:#fff; color:#1d4ed8;">
            <i class="fa fa-clock-o"></i> الطلبات المعلقة
        </a>
    </div>

    <!-- Stats -->
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 14px; margin-bottom: 18px;">
        <div class="et-card" style="margin: 0; padding: 18px; display:flex; align-items:center; gap:12px;">
            <div style="width:46px; height:46px; border-radius:12px; background:linear-gradient(135deg,#60a5fa,#1d4ed8); color:#fff; display:grid; place-items:center; font-size:20px;"><i class="fa fa-list"></i></div>
            <div><div style="font-size:11px; color:#64748b; font-weight:600;">إجمالي الطلبات</div><div style="font-size:22px; font-weight:800; color:#0f172a;">@(Model?.Count ?? 0)</div></div>
        </div>
        <div class="et-card" style="margin: 0; padding: 18px; display:flex; align-items:center; gap:12px;">
            <div style="width:46px; height:46px; border-radius:12px; background:linear-gradient(135deg,#34d399,#059669); color:#fff; display:grid; place-items:center; font-size:20px;"><i class="fa fa-money"></i></div>
            <div><div style="font-size:11px; color:#64748b; font-weight:600;">إجمالي المعتمد</div><div style="font-size:22px; font-weight:800; color:#16a34a;">@totalApproved.ToString("N2") <small style="font-size:12px;">جنيه</small></div></div>
        </div>
        <div class="et-card" style="margin: 0; padding: 18px; display:flex; align-items:center; gap:12px;">
            <div style="width:46px; height:46px; border-radius:12px; background:linear-gradient(135deg,#fbbf24,#d97706); color:#fff; display:grid; place-items:center; font-size:20px;"><i class="fa fa-exclamation-triangle"></i></div>
            <div><div style="font-size:11px; color:#64748b; font-weight:600;">طلبات بفروقات</div><div style="font-size:22px; font-weight:800; color:#0f172a;">@discCount</div></div>
        </div>
    </div>

    <!-- Filters -->
    <div class="et-card" style="padding: 14px 18px;">
        <div style="display:flex; gap:8px; flex-wrap:wrap;">
            <a href="@Url.Action("All")" class="et-btn et-btn-sm @(statusFilter == null ? "et-btn-primary" : "et-btn-cancel")">الكل</a>
            <a href="@Url.Action("All", new { status = (int)PostexS.Models.Enums.TransferRequestStatus.Pending })" class="et-btn et-btn-sm @(statusFilter == PostexS.Models.Enums.TransferRequestStatus.Pending ? "et-btn-warn" : "et-btn-cancel")">معلق</a>
            <a href="@Url.Action("All", new { status = (int)PostexS.Models.Enums.TransferRequestStatus.Approved })" class="et-btn et-btn-sm @(statusFilter == PostexS.Models.Enums.TransferRequestStatus.Approved ? "et-btn-primary" : "et-btn-cancel")">مقبول</a>
            <a href="@Url.Action("All", new { status = (int)PostexS.Models.Enums.TransferRequestStatus.Rejected })" class="et-btn et-btn-sm @(statusFilter == PostexS.Models.Enums.TransferRequestStatus.Rejected ? "et-btn-danger" : "et-btn-cancel")">مرفوض</a>
        </div>
    </div>

    <div class="et-card">
        @if (Model == null || Model.Count == 0)
        {
            <div class="et-empty">
                <i class="fa fa-inbox"></i>
                <strong>لا توجد طلبات</strong>
            </div>
        }
        else
        {
            <div style="overflow-x:auto;">
                <table class="et-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>الموظف</th>
                            <th>المُقدَّم</th>
                            <th>المُعتمد</th>
                            <th>الحالة</th>
                            <th>الأدمن</th>
                            <th>تاريخ التقديم</th>
                            <th>تاريخ المعالجة</th>
                            <th>ملاحظات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            var statusCls = item.Status == PostexS.Models.Enums.TransferRequestStatus.Pending ? "pending"
                                          : item.Status == PostexS.Models.Enums.TransferRequestStatus.Approved ? "approved" : "rejected";
                            var statusText = item.Status == PostexS.Models.Enums.TransferRequestStatus.Pending ? "معلق"
                                           : item.Status == PostexS.Models.Enums.TransferRequestStatus.Approved ? "مقبول" : "مرفوض";
                            <tr>
                                <td><strong>#@item.Id</strong></td>
                                <td>
                                    <strong>@(item.Employee?.Name ?? "—")</strong>
                                    <div class="et-meta">@(item.Employee?.UserName ?? "")</div>
                                </td>
                                <td><span class="et-amount">@item.RequestedAmount.ToString("0.##")</span></td>
                                <td>
                                    @if (item.ApprovedAmount.HasValue)
                                    {
                                        <span class="et-amount @(item.HasDiscrepancy ? "out" : "in")">@item.ApprovedAmount.Value.ToString("0.##")</span>
                                        @if (item.HasDiscrepancy) { <div><span class="et-disc-badge"><i class="fa fa-exclamation-triangle"></i> فرق</span></div> }
                                    }
                                    else { <span style="color:#cbd5e1;">—</span> }
                                </td>
                                <td><span class="et-badge @statusCls"><span class="dot"></span> @statusText</span></td>
                                <td>@(item.Admin?.Name ?? "—")</td>
                                <td>@item.CreateOn.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                                <td>@(item.ProcessedAt?.ToLocalTime().ToString("yyyy-MM-dd HH:mm") ?? "—")</td>
                                <td style="max-width:240px; font-size:12px;">
                                    @if (!string.IsNullOrEmpty(item.EmployeeNotes)) { <div><strong>موظف:</strong> @item.EmployeeNotes</div> }
                                    @if (!string.IsNullOrEmpty(item.AdminNotes))    { <div class="et-meta" style="margin-top:3px;"><strong>أدمن:</strong> @item.AdminNotes</div> }
                                    @if (item.HasDiscrepancy && !string.IsNullOrEmpty(item.DiscrepancyNote))
                                    {
                                        <div style="margin-top:4px; font-size:10.5px; color:#78350f; background:#fef3c7; padding:4px 6px; border-radius:5px;"><i class="fa fa-info-circle"></i> @item.DiscrepancyNote</div>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
