@model PostexS.Helper.PagedList<PostexS.Models.Domain.CourierOrderSheet>
@using PostexS.Models.ViewModels;
@using PostexS.Helper
@using PostexS.Models.Domain;

@{
    ViewData["Title"] = "قوائم تحميل المندوبين";
    var drivers = ViewBag.Drivers as List<ApplicationUser>;
    var courierId = ViewBag.CourierId as string;

    var paginationVM = new PaginationVM()
            {
                PageIndex = Model.PageIndex,
                TotalPages = Model.TotalPages,
                PreviousPage = Model.PreviousPage,
                NextPage = Model.NextPage,
                GetItemsUrl = "/Orders/GetItemsCourierSheets",
                GetPaginationUrl = "/Orders/GetPaginationCourierSheets",
                ItemsCount = Model.ItemsCount,
                StartIndex = Model.StartIndex,
                EndIndex = Model.EndIndex
            };

    DateTime FilterTime = new DateTime();
    if (ViewBag.FilterTime != null) FilterTime = ViewBag.FilterTime;
    DateTime FilterTimeTo = new DateTime();
    if (ViewBag.FilterTimeTo != null) FilterTimeTo = ViewBag.FilterTimeTo;
}

<div class="panel panel-primary">
    <div class="panel-heading">
        <h3 class="panel-title"><i class="fa fa-fw fa-list-alt"></i> قوائم تحميل المندوبين</h3>
    </div>

    <div class="form-group">
        <label for="CourierIdFilter">اختيار المندوب</label>
        <select name="CourierIdFilter" id="CourierIdFilter" class="select form-control">
            @if (courierId == "0")
            {
                <option value="0" selected>الجميع</option>
            }
            else
            {
                <option value="0">الجميع</option>
            }
            @foreach (var driver in drivers)
            {
                if (courierId == driver.Id)
                {
                    <option selected value="@driver.Id">@driver.Name</option>
                }
                else
                {
                    <option value="@driver.Id">@driver.Name</option>
                }
            }
        </select>
    </div>

    <label class="text-center">اختر المدة</label>
    <div class="row">
        <div class="col-lg-2 text-center"></div>
        <div class="col-lg-3">
            <input name="FilterTime" id="FilterTime" value="@FilterTime.Date" type="date" class="form-control" />
        </div>
        <div class="col-lg-2 text-center">
            <label style="vertical-align:central" class="text-center">إلــى</label>
        </div>
        <div class="col-lg-3">
            <input name="FilterTimeTo" id="FilterTimeTo" value="@FilterTimeTo.Date" type="date" class="form-control" />
        </div>
        <div class="col-lg-2">
            <a onclick="ReloadPagination(1)" class="btn btn-primary form-control">بحــث</a>
        </div>
    </div>

    <div class="panel-body">
        <div class="row">
            <div class="col-sm-3">
                <table>
                    <tr>
                        <td><span>عرض </span></td>
                        <td>
                            <select class="form-control" onchange="ReloadPagination(1)" id="entires">
                                <option value="5">5</option>
                                <option value="10">10</option>
                                <option value="25">25</option>
                                <option value="50" selected="selected">50</option>
                                <option value="100">100</option>
                            </select>
                        </td>
                        <td><span> من المدخلات</span></td>
                    </tr>
                </table>
            </div>
        </div>

        <div class="table-responsive text-center">
            <table id="tableSheets" cellpadding="0" cellspacing="0" border="0" class="table table-striped table-bordered table-hover">
                <thead>
                    <tr>
                        <th style="text-align:center">#</th>
                        <th style="text-align:center">المندوب</th>
                        <th style="text-align:center">عدد الطلبات</th>
                        <th style="text-align:center">التاريخ</th>
                        <th style="text-align:center">بواسطة</th>
                        <th style="text-align:center">التحكم</th>
                    </tr>
                </thead>
                <tbody id="tbBody" style="text-align:center">
                    <partial name="_TableListCourierSheets" model="@Model.ToList()" />
                </tbody>
            </table>
            <div id="dvPagination">
                @{
                    var prevDisabled = !paginationVM.PreviousPage ? "disabled" : "";
                    var nextDisabled = !paginationVM.NextPage ? "disabled" : "";
                    var tbl_footer_msg = "عرض " + paginationVM.StartIndex + " الى " + paginationVM.EndIndex + " من " + paginationVM.ItemsCount + " مدخلات ";
                    var pgIndex = 1;
                    var pgEnd = 10;
                    if (paginationVM.PageIndex > 5)
                    {
                        pgIndex = paginationVM.PageIndex - 5;
                        pgEnd = paginationVM.PageIndex + 5;
                    }
                }
                <div class="row">
                    <div class="col-sm-4 mt-15">
                        <p>@tbl_footer_msg</p>
                    </div>
                    <div class="col-sm-8" style="text-align:left">
                        <a class="btn btn-default btnpagination @prevDisabled"
                           onclick="ReloadPagination(@(paginationVM.PageIndex - 1))">السابق</a>
                        @for (var i = pgIndex; i <= pgEnd; i++)
                        {
                            if (paginationVM.PageIndex == i)
                            {
                                <a class="btn btn-info btnpagination" onclick="ReloadPagination(@i)">@i</a>
                            }
                            else
                            {
                                <a class="btn btn-default btnpagination" onclick="ReloadPagination(@i)">@i</a>
                            }
                        }
                        <a class="btn btn-default btnpagination @nextDisabled"
                           onclick="ReloadPagination(@(paginationVM.PageIndex + 1))">التالي</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal اختيار أعمدة Excel -->
<div class="modal fade" id="excelColumnsModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>
                <h4 class="modal-title"><i class="fa fa-columns"></i> اختر الأعمدة الإضافية في ملف Excel</h4>
            </div>
            <div class="modal-body">
                <input type="hidden" id="exportSheetId" />
                <div style="display:flex; flex-wrap:wrap; gap:15px;">
                    <label style="cursor:pointer;"><input type="checkbox" class="excel-col-option" data-col="showProductName" /> اسم المنتج</label>
                    <label style="cursor:pointer;"><input type="checkbox" class="excel-col-option" data-col="showSenderPhone" /> رقم تليفون الراسل</label>
                    <label style="cursor:pointer;"><input type="checkbox" class="excel-col-option" data-col="showSenderName" /> اسم الراسل</label>
                    <label style="cursor:pointer;"><input type="checkbox" class="excel-col-option" data-col="showOrderCost" /> سعر الطلب</label>
                    <label style="cursor:pointer;"><input type="checkbox" class="excel-col-option" data-col="showDeliveryFees" /> سعر الشحن</label>
                    <label style="cursor:pointer;"><input type="checkbox" class="excel-col-option" data-col="showClientCode" /> كود العميل</label>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-default" data-dismiss="modal">إلغاء</button>
                <button type="button" class="btn btn-warning" onclick="doExcelExport()"><i class="fa fa-file-excel"></i> تحميل Excel</button>
            </div>
        </div>
    </div>
</div>

<script type="text/javascript">
    function openExcelExport(sheetId) {
        document.getElementById('exportSheetId').value = sheetId;
        // reset checkboxes
        document.querySelectorAll('.excel-col-option').forEach(function (cb) { cb.checked = false; });
        $('#excelColumnsModal').modal('show');
    }

    function doExcelExport() {
        var sheetId = document.getElementById('exportSheetId').value;
        var url = '/Orders/ExportSheetExcel?id=' + sheetId + '&useCustomColumns=true';
        document.querySelectorAll('.excel-col-option').forEach(function (cb) {
            url += '&' + cb.getAttribute('data-col') + '=' + cb.checked;
        });
        window.location.href = url;
        $('#excelColumnsModal').modal('hide');
    }

    function ReloadPagination(pageNum) {
        var courierId = document.getElementById("CourierIdFilter").value;
        var FilterTime = document.getElementById("FilterTime").value;
        var FilterTimeTo = document.getElementById("FilterTimeTo").value;
        var pageSize = 50;
        if ($("#entires") != null || $("#entires") != undefined) {
            pageSize = $("#entires").val();
        }
        $.ajax({
            url: "/Orders/GetItemsCourierSheets",
            type: "GET",
            data: { courierId: courierId, FilterTime: FilterTime, FilterTimeTo: FilterTimeTo, pageNumber: pageNum, pageSize: pageSize },
            success: function (results) {
                $("#tbBody").empty();
                $("#tbBody").html(results);
                $.ajax({
                    url: "/Orders/GetPaginationCourierSheets",
                    type: "GET",
                    data: { courierId: courierId, FilterTime: FilterTime, FilterTimeTo: FilterTimeTo, pageNumber: pageNum, pageSize: pageSize },
                    success: function (results) {
                        $("#dvPagination").empty();
                        $("#dvPagination").html(results);
                    }
                });
            }
        });
    }
</script>

<script>
    $(document).ready(function () {
        $("#tableSheets").DataTable({
            paging: false,
            ordering: false,
            info: false,
            searching: false
        });
    });
</script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
