@using PostexS.Models.Domain
@model List<Order>
@{
    ViewData["Title"] = "استلام مخزن";
    var branchs = ViewBag.Branchs as List<Branch>;
    long selectedBranch = ViewBag.BranchId != null ? (long)ViewBag.BranchId : -1;
    var egyptTZ = TimeZoneInfo.FindSystemTimeZoneById("Egypt Standard Time");
}

<style>
    .wh-hero {
        background: linear-gradient(135deg, #145a32 0%, #27ae60 50%, #145a32 100%);
        border-radius: 12px;
        padding: 26px 30px;
        margin-bottom: 22px;
        position: relative;
        overflow: hidden;
        box-shadow: 0 8px 32px rgba(20, 90, 50, 0.22);
    }
    .wh-hero h2 { color: #fff; margin: 0 0 6px 0; font-size: 22px; font-weight: 700; }
    .wh-hero p { color: rgba(255,255,255,0.85); margin: 0; font-size: 14px; }
    .wh-hero .hero-icon { position: absolute; left: 28px; top: 50%; transform: translateY(-50%); font-size: 46px; color: rgba(255,255,255,0.15); }

    .wh-card { background:#fff; border-radius:10px; box-shadow:0 2px 12px rgba(0,0,0,0.06); border:1px solid #e8ecf1; margin-bottom:20px; overflow:hidden; }
    .wh-card-head { padding:16px 20px; border-bottom:1px solid #f0f2f5; display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:12px; }
    .wh-card-head h4 { margin:0; font-size:16px; font-weight:600; color:#145a32; }
    .wh-card-body { padding:20px; }

    .wh-actions { display:flex; gap:12px; flex-wrap:wrap; align-items:center; margin-bottom:16px; }
    .btn-wh { padding:10px 22px; border-radius:8px; font-weight:600; font-size:14px; border:none; cursor:pointer; transition:all .2s; display:inline-flex; align-items:center; gap:8px; }
    .btn-wh:hover { transform:translateY(-1px); box-shadow:0 4px 12px rgba(0,0,0,.15); }
    .btn-wh:disabled { opacity:.5; cursor:not-allowed; transform:none; box-shadow:none; }
    .btn-accept { background:linear-gradient(135deg,#27ae60,#2ecc71); color:#fff; }
    .btn-reject { background:linear-gradient(135deg,#c0392b,#e74c3c); color:#fff; }

    .wh-empty { text-align:center; padding:48px; color:#9aa; }
    .wh-empty i { font-size:56px; color:#d5dbe0; margin-bottom:14px; }

    .count-badge { background:#27ae60; color:#fff; border-radius:20px; padding:3px 12px; font-size:13px; font-weight:700; }

    .scan-box {
        background: #eef7f1; border: 2px dashed #27ae60; border-radius: 10px;
        padding: 16px 18px; margin-bottom: 16px;
    }
    .scan-box label { display:block; font-weight:700; color:#145a32; margin-bottom:8px; font-size:14px; }
    .scan-box input {
        width: 100%; max-width: 420px; padding: 12px 14px; font-size: 18px; font-weight: 700;
        border: 2px solid #27ae60; border-radius: 8px; text-align: center; letter-spacing: 1px;
    }
    .scan-box input:focus { outline: none; box-shadow: 0 0 0 3px rgba(39,174,96,0.2); }
    .scan-box .scan-hint { display:inline-block; margin-right:12px; color:#7f8c8d; font-size:12px; }
    .scan-log { max-height: 180px; overflow-y: auto; margin-bottom: 16px; }
    .scan-line { padding: 6px 12px; border-radius: 6px; margin-bottom: 5px; font-size: 13px; font-weight: 600; }
    .scan-line.ok { background: #eafaf1; color: #1e8449; border: 1px solid #a9dfbf; }
    .scan-line.err { background: #fdecea; color: #c0392b; border: 1px solid #f5b7b1; }

    @@media (max-width:768px) {
        .wh-hero .hero-icon { display:none; }
        .wh-actions { flex-direction:column; }
        .btn-wh { width:100%; justify-content:center; }
        .scan-box input { max-width: 100%; }
    }
</style>

<div class="wh-hero">
    <i class="fa fa-inbox hero-icon"></i>
    <h2><i class="fa fa-inbox"></i> استلام مخزن</h2>
    <p>الطلبات المُدخَلة من حسابات إدخال البيانات بتنتظر هنا استلام المخزن — راجعها واقبلها أو ارفضها</p>
</div>

<div class="wh-card">
    <div class="wh-card-head">
        <h4><i class="fa fa-clock-o"></i> طلبات بانتظار الاستلام <span class="count-badge" id="pendingCount">@Model.Count</span></h4>
        <form method="get" style="margin:0;">
            <select name="BranchId" class="form-control" style="display:inline-block;width:auto;" onchange="this.form.submit()">
                <option value="-1">كل الفروع</option>
                @if (branchs != null)
                {
                    foreach (var b in branchs)
                    {
                        if (b.Id == selectedBranch)
                        {
                            <option value="@b.Id" selected>@b.Name</option>
                        }
                        else
                        {
                            <option value="@b.Id">@b.Name</option>
                        }
                    }
                }
            </select>
        </form>
    </div>
    <div class="wh-card-body">
        @if (Model.Count == 0)
        {
            <div class="wh-empty">
                <div><i class="fa fa-check-circle"></i></div>
                <p>مفيش طلبات بانتظار الاستلام حالياً</p>
                <p style="font-size:13px; max-width:600px; margin:10px auto 0; color:#8a97a3; line-height:2;">
                    الطلبات بتظهر هنا لما حساب <b>إدخال بيانات</b> مفعّل عليه خيار «استلام مخزن» يدخّل طلبات جديدة.<br />
                    فعّل الخيار من: <b>المستخدمين ← تعديل الحساب ← «توجيه طلبات الحساب لاستلام المخزن»</b>،
                    وبعدها أي طلب الحساب ده يدخّله هييجي هنا تستلمه <b>بمسح الباركود (Scan)</b> أو بالاختيار اليدوي.
                </p>
            </div>
        }
        else
        {
            <div class="scan-box">
                <label><i class="fa fa-barcode"></i> استلام بالمسح — امسح باركود الشحنة (أو اكتب الكود واضغط Enter):</label>
                <input type="text" id="scanInput" autocomplete="off" placeholder="امسح الباركود هنا..." />
                <span class="scan-hint">كل مسح بيستلم الشحنة على طول</span>
            </div>
            <div id="scanLog" class="scan-log"></div>

            <div class="wh-actions">
                <button class="btn-wh btn-accept" id="acceptBtn" onclick="doAction('accept')" disabled>
                    <i class="fa fa-check"></i> استلام المحدد (<span id="accCount">0</span>)
                </button>
                <button class="btn-wh btn-reject" id="rejectBtn" onclick="doAction('reject')" disabled>
                    <i class="fa fa-times"></i> رفض المحدد
                </button>
            </div>
            <div class="table-responsive" id="whTableWrap">
                <table class="table table-striped table-bordered table-hover" style="text-align:center;">
                    <thead>
                        <tr>
                            <th><input type="checkbox" id="selectAll" onclick="toggleAll(this)" /></th>
                            <th>كود الشحنة</th>
                            <th>الراسل</th>
                            <th>المرسل إليه</th>
                            <th>الهاتف</th>
                            <th>العنوان</th>
                            <th>الإجمالي</th>
                            <th>تاريخ الإدخال</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var o in Model)
                        {
                            <tr data-code="@o.Code">
                                <td><input type="checkbox" class="rowChk" value="@o.Id" onclick="updateSel()" /></td>
                                <td><span class="badge bg-blue-active">@o.Code</span></td>
                                <td>@(o.Client != null ? o.Client.Name : "-")</td>
                                <td>@o.ClientName</td>
                                <td>@o.ClientPhone</td>
                                <td style="max-width:180px;">@o.AddressCity - @o.Address</td>
                                <td>@o.TotalCost.ToString("N2")</td>
                                <td><small>@TimeZoneInfo.ConvertTimeFromUtc(o.CreateOn, egyptTZ).ToString("dd/MM/yyyy hh:mm tt")</small></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<script>
    function getSelected() {
        return $('.rowChk:checked').map(function () { return parseInt(this.value); }).get();
    }
    function updateSel() {
        var n = getSelected().length;
        $('#accCount').text(n);
        $('#acceptBtn').prop('disabled', n === 0);
        $('#rejectBtn').prop('disabled', n === 0);
        var total = $('.rowChk').length;
        $('#selectAll').prop('checked', n === total && total > 0);
    }
    function toggleAll(cb) {
        $('.rowChk').prop('checked', cb.checked);
        updateSel();
    }

    function doAction(kind) {
        var ids = getSelected();
        if (ids.length === 0) return;

        var isAccept = kind === 'accept';
        swal({
            title: isAccept ? "تأكيد الاستلام" : "تأكيد الرفض",
            text: isAccept
                ? ("هيتم استلام " + ids.length + " طلب وتشغيلها عادي.")
                : ("هيتم رفض " + ids.length + " طلب (هيتشالوا). متأكد؟"),
            icon: "warning",
            buttons: ["إلغاء", isAccept ? "نعم، استلم" : "نعم، ارفض"],
            dangerMode: !isAccept,
        }).then(function (ok) {
            if (!ok) return;
            var url = isAccept
                ? '@Url.Action("AcceptWarehouseOrders", "Orders")'
                : '@Url.Action("RejectWarehouseOrders", "Orders")';
            $.ajax({
                url: url,
                type: 'POST',
                traditional: true,
                data: { Orders: ids },
                success: function (res) {
                    if (res.success) {
                        swal("تم", res.message, "success").then(function () { location.reload(); });
                    } else {
                        swal("خطأ", res.message || "حدث خطأ", "error");
                    }
                },
                error: function () { swal("خطأ", "حدث خطأ أثناء التنفيذ", "error"); }
            });
        });
    }

    // ===== الاستلام بالمسح (Scan) =====
    (function () {
        var $scan = $('#scanInput');
        if (!$scan.length) return;

        function focusScan() { $scan.trigger('focus'); }
        focusScan();

        // ===== بيب صوتي (Web Audio — من غير ملفات) =====
        var audioCtx = null;
        function beep(freq, duration, type, vol) {
            try {
                var AC = window.AudioContext || window.webkitAudioContext;
                if (!AC) return;
                if (!audioCtx) audioCtx = new AC();
                if (audioCtx.state === 'suspended') audioCtx.resume();
                var osc = audioCtx.createOscillator();
                var gain = audioCtx.createGain();
                osc.type = type || 'sine';
                osc.frequency.value = freq;
                gain.gain.value = vol || 0.15;
                osc.connect(gain);
                gain.connect(audioCtx.destination);
                osc.start();
                osc.stop(audioCtx.currentTime + duration);
            } catch (e) { }
        }
        function beepOk() { beep(1000, 0.12, 'sine', 0.15); }        // نجاح: نبرة عالية قصيرة
        function beepErr() { beep(200, 0.45, 'square', 0.2); }       // خطأ: نبرة منخفضة أطول (بازر)

        function logLine(cls, text) {
            $('#scanLog').prepend('<div class="scan-line ' + cls + '">' + text + '</div>');
        }

        function refreshCount() {
            var n = $('.rowChk').length;
            $('#pendingCount').text(n);
            if (n === 0) {
                $('#whTableWrap').html('<div class="wh-empty" style="padding:24px;"><div><i class="fa fa-check-circle" style="color:#27ae60;"></i></div><p>تم استلام كل الطلبات ✅</p></div>');
                $('#acceptBtn, #rejectBtn').prop('disabled', true);
            }
        }

        $scan.on('keydown', function (e) {
            if (e.key !== 'Enter' && e.keyCode !== 13) return;
            e.preventDefault();
            var code = ($scan.val() || '').trim();
            $scan.val('');
            if (!code) return;

            $.ajax({
                url: '@Url.Action("AcceptWarehouseOrderByCode", "Orders")',
                type: 'POST',
                global: false, // منمنع اللودر العام إنه يومض مع كل مسح
                data: { code: code },
                success: function (res) {
                    if (res && res.success) {
                        beepOk();
                        logLine('ok', '✅ ' + res.message + (res.recipient ? ' — ' + res.recipient : ''));
                        if (typeof toastr !== 'undefined') toastr.success(res.message);
                        var row = $('tr[data-code="' + code + '"]');
                        if (row.length) { row.fadeOut(180, function () { $(this).remove(); refreshCount(); }); }
                        else { refreshCount(); }
                    } else {
                        beepErr();
                        logLine('err', '❌ ' + (res ? res.message : 'خطأ'));
                        if (typeof toastr !== 'undefined') toastr.error(res ? res.message : 'خطأ');
                    }
                },
                error: function () { beepErr(); logLine('err', '❌ حصل خطأ أثناء الاستلام، جرّب تاني'); },
                complete: function () { focusScan(); }
            });
        });
    })();
</script>
