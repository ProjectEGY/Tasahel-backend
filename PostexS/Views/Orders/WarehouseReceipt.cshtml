@using PostexS.Models.Domain
@model List<Order>
@{
    ViewData["Title"] = "استلام مخزن";
    var branchs = ViewBag.Branchs as List<Branch>;
    long selectedBranch = ViewBag.BranchId != null ? (long)ViewBag.BranchId : -1;
    var egyptTZ = TimeZoneInfo.FindSystemTimeZoneById("Egypt Standard Time");
}

<style>
    .wh-hero {
        background: linear-gradient(135deg, #145a32 0%, #27ae60 50%, #145a32 100%);
        border-radius: 12px;
        padding: 26px 30px;
        margin-bottom: 22px;
        position: relative;
        overflow: hidden;
        box-shadow: 0 8px 32px rgba(20, 90, 50, 0.22);
    }
    .wh-hero h2 { color: #fff; margin: 0 0 6px 0; font-size: 22px; font-weight: 700; }
    .wh-hero p { color: rgba(255,255,255,0.85); margin: 0; font-size: 14px; }
    .wh-hero .hero-icon { position: absolute; left: 28px; top: 50%; transform: translateY(-50%); font-size: 46px; color: rgba(255,255,255,0.15); }

    .wh-card { background:#fff; border-radius:10px; box-shadow:0 2px 12px rgba(0,0,0,0.06); border:1px solid #e8ecf1; margin-bottom:20px; overflow:hidden; }
    .wh-card-head { padding:16px 20px; border-bottom:1px solid #f0f2f5; display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:12px; }
    .wh-card-head h4 { margin:0; font-size:16px; font-weight:600; color:#145a32; }
    .wh-card-body { padding:20px; }

    .wh-actions { display:flex; gap:12px; flex-wrap:wrap; align-items:center; margin-bottom:16px; }
    .btn-wh { padding:10px 22px; border-radius:8px; font-weight:600; font-size:14px; border:none; cursor:pointer; transition:all .2s; display:inline-flex; align-items:center; gap:8px; }
    .btn-wh:hover { transform:translateY(-1px); box-shadow:0 4px 12px rgba(0,0,0,.15); }
    .btn-wh:disabled { opacity:.5; cursor:not-allowed; transform:none; box-shadow:none; }
    .btn-accept { background:linear-gradient(135deg,#27ae60,#2ecc71); color:#fff; }
    .btn-reject { background:linear-gradient(135deg,#c0392b,#e74c3c); color:#fff; }

    .wh-empty { text-align:center; padding:48px; color:#9aa; }
    .wh-empty i { font-size:56px; color:#d5dbe0; margin-bottom:14px; }

    .count-badge { background:#27ae60; color:#fff; border-radius:20px; padding:3px 12px; font-size:13px; font-weight:700; }

    @@media (max-width:768px) {
        .wh-hero .hero-icon { display:none; }
        .wh-actions { flex-direction:column; }
        .btn-wh { width:100%; justify-content:center; }
    }
</style>

<div class="wh-hero">
    <i class="fa fa-inbox hero-icon"></i>
    <h2><i class="fa fa-inbox"></i> استلام مخزن</h2>
    <p>الطلبات المُدخَلة من حسابات إدخال البيانات بتنتظر هنا استلام المخزن — راجعها واقبلها أو ارفضها</p>
</div>

<div class="wh-card">
    <div class="wh-card-head">
        <h4><i class="fa fa-clock-o"></i> طلبات بانتظار الاستلام <span class="count-badge">@Model.Count</span></h4>
        <form method="get" style="margin:0;">
            <select name="BranchId" class="form-control" style="display:inline-block;width:auto;" onchange="this.form.submit()">
                <option value="-1">كل الفروع</option>
                @if (branchs != null)
                {
                    foreach (var b in branchs)
                    {
                        if (b.Id == selectedBranch)
                        {
                            <option value="@b.Id" selected>@b.Name</option>
                        }
                        else
                        {
                            <option value="@b.Id">@b.Name</option>
                        }
                    }
                }
            </select>
        </form>
    </div>
    <div class="wh-card-body">
        @if (Model.Count == 0)
        {
            <div class="wh-empty">
                <div><i class="fa fa-check-circle"></i></div>
                <p>مفيش طلبات بانتظار الاستلام حالياً</p>
            </div>
        }
        else
        {
            <div class="wh-actions">
                <button class="btn-wh btn-accept" id="acceptBtn" onclick="doAction('accept')" disabled>
                    <i class="fa fa-check"></i> استلام المحدد (<span id="accCount">0</span>)
                </button>
                <button class="btn-wh btn-reject" id="rejectBtn" onclick="doAction('reject')" disabled>
                    <i class="fa fa-times"></i> رفض المحدد
                </button>
            </div>
            <div class="table-responsive">
                <table class="table table-striped table-bordered table-hover" style="text-align:center;">
                    <thead>
                        <tr>
                            <th><input type="checkbox" id="selectAll" onclick="toggleAll(this)" /></th>
                            <th>كود الشحنة</th>
                            <th>الراسل</th>
                            <th>المرسل إليه</th>
                            <th>الهاتف</th>
                            <th>العنوان</th>
                            <th>الإجمالي</th>
                            <th>تاريخ الإدخال</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var o in Model)
                        {
                            <tr>
                                <td><input type="checkbox" class="rowChk" value="@o.Id" onclick="updateSel()" /></td>
                                <td><span class="badge bg-blue-active">@o.Code</span></td>
                                <td>@(o.Client != null ? o.Client.Name : "-")</td>
                                <td>@o.ClientName</td>
                                <td>@o.ClientPhone</td>
                                <td style="max-width:180px;">@o.AddressCity - @o.Address</td>
                                <td>@o.TotalCost.ToString("N2")</td>
                                <td><small>@TimeZoneInfo.ConvertTimeFromUtc(o.CreateOn, egyptTZ).ToString("dd/MM/yyyy hh:mm tt")</small></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<script>
    function getSelected() {
        return $('.rowChk:checked').map(function () { return parseInt(this.value); }).get();
    }
    function updateSel() {
        var n = getSelected().length;
        $('#accCount').text(n);
        $('#acceptBtn').prop('disabled', n === 0);
        $('#rejectBtn').prop('disabled', n === 0);
        var total = $('.rowChk').length;
        $('#selectAll').prop('checked', n === total && total > 0);
    }
    function toggleAll(cb) {
        $('.rowChk').prop('checked', cb.checked);
        updateSel();
    }

    function doAction(kind) {
        var ids = getSelected();
        if (ids.length === 0) return;

        var isAccept = kind === 'accept';
        swal({
            title: isAccept ? "تأكيد الاستلام" : "تأكيد الرفض",
            text: isAccept
                ? ("هيتم استلام " + ids.length + " طلب وتشغيلها عادي.")
                : ("هيتم رفض " + ids.length + " طلب (هيتشالوا). متأكد؟"),
            icon: "warning",
            buttons: ["إلغاء", isAccept ? "نعم، استلم" : "نعم، ارفض"],
            dangerMode: !isAccept,
        }).then(function (ok) {
            if (!ok) return;
            var url = isAccept
                ? '@Url.Action("AcceptWarehouseOrders", "Orders")'
                : '@Url.Action("RejectWarehouseOrders", "Orders")';
            $.ajax({
                url: url,
                type: 'POST',
                traditional: true,
                data: { Orders: ids },
                success: function (res) {
                    if (res.success) {
                        swal("تم", res.message, "success").then(function () { location.reload(); });
                    } else {
                        swal("خطأ", res.message || "حدث خطأ", "error");
                    }
                },
                error: function () { swal("خطأ", "حدث خطأ أثناء التنفيذ", "error"); }
            });
        });
    }
</script>
