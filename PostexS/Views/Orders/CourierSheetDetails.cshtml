@model List<PostexS.Models.Domain.CourierOrderSheetItem>
@using PostexS.Models.Enums;
@using PostexS.Models.Domain;

@{
    var sheet = ViewBag.Sheet as CourierOrderSheet;
    ViewData["Title"] = "تفاصيل القائمة #" + sheet.Id;
    var CreatedOn = TimeZoneInfo.ConvertTimeFromUtc(sheet.CreateOn, TimeZoneInfo.FindSystemTimeZoneById("Sudan Standard Time"));
}

<div class="panel panel-primary">
    <div class="panel-heading">
        <h3 class="panel-title"><i class="fa fa-fw fa-list"></i> تفاصيل القائمة #@sheet.Id</h3>
    </div>

    <div class="panel-body">
        <div class="row" style="margin-bottom:15px;">
            <div class="col-md-3">
                <strong>المندوب:</strong> @(sheet.Courier?.Name ?? "-")
            </div>
            <div class="col-md-3">
                <strong>عدد الطلبات:</strong> @sheet.TotalOrders
            </div>
            <div class="col-md-3">
                <strong>التاريخ:</strong> @CreatedOn.ToString("dd MMMM yyyy - hh:mm tt")
            </div>
            <div class="col-md-3">
                <strong>بواسطة:</strong> @(sheet.CreatedBy?.Name ?? "-")
            </div>
        </div>

        <!-- اختيار الأعمدة الاختيارية في Excel -->
        <div style="background:#f8f9fa; border:1px solid #ddd; border-radius:8px; padding:15px; margin-bottom:15px;">
            <h5 style="margin-bottom:10px; font-weight:bold;"><i class="fa fa-columns"></i> اختر الأعمدة الإضافية في ملف Excel:</h5>
            <div style="display:flex; flex-wrap:wrap; gap:15px;">
                <label style="cursor:pointer;"><input type="checkbox" class="excel-col-option" data-col="showProductName" /> اسم المنتج</label>
                <label style="cursor:pointer;"><input type="checkbox" class="excel-col-option" data-col="showSenderPhone" /> رقم تليفون الراسل</label>
                <label style="cursor:pointer;"><input type="checkbox" class="excel-col-option" data-col="showSenderName" /> اسم الراسل</label>
                <label style="cursor:pointer;"><input type="checkbox" class="excel-col-option" data-col="showOrderCost" /> سعر الطلب</label>
                <label style="cursor:pointer;"><input type="checkbox" class="excel-col-option" data-col="showDeliveryFees" /> سعر الشحن</label>
                <label style="cursor:pointer;"><input type="checkbox" class="excel-col-option" data-col="showClientCode" /> كود العميل</label>
            </div>
        </div>

        <div class="row" style="margin-bottom:15px;">
            <div class="col-md-12">
                <a class="btn btn-warning" href="javascript:void(0)" onclick="exportSheetExcel()">
                    <i class="fa fa-file-excel"></i> تحميل Excel
                </a>
                <a class="btn btn-default" href="/Orders/CourierSheets">
                    <i class="fa fa-arrow-right"></i> رجوع للقوائم
                </a>
            </div>
        </div>

        <div class="table-responsive text-center">
            <table id="tableDetails" cellpadding="0" cellspacing="0" border="0" class="table table-striped table-bordered table-hover">
                <thead>
                    <tr>
                        <th style="text-align:center">#</th>
                        <th style="text-align:center">كود الطلب</th>
                        <th style="text-align:center">المرسل إليه</th>
                        <th style="text-align:center">تليفون المرسل إليه</th>
                        <th style="text-align:center">المحافظة</th>
                        <th style="text-align:center">العنوان</th>
                        <th style="text-align:center">المطلوب دفعه</th>
                        <th style="text-align:center">الراسل</th>
                        <th style="text-align:center">الحالة</th>
                        <th style="text-align:center">الملاحظات</th>
                    </tr>
                </thead>
                <tbody style="text-align:center">
                    @{var counter = 0;}
                    @foreach (var item in Model)
                    {
                        counter++;
                        if (item.Order == null) continue;
                        var order = item.Order;
                        <tr>
                            <td>@counter</td>
                            <td>@order.Code</td>
                            <td>@order.ClientName</td>
                            <td>@order.ClientPhone</td>
                            <td>@order.AddressCity</td>
                            <td>@order.Address</td>
                            <td>@order.TotalCost</td>
                            <td>@(order.Client?.Name ?? "-")</td>
                            <td>
                                @switch (order.Status)
                                {
                                    case OrderStatus.Placed:
                                        <span class="badge bg-yellow">جديد</span>
                                        break;
                                    case OrderStatus.Assigned:
                                        <span class="badge bg-light-blue">جارى التوصيل</span>
                                        break;
                                    case OrderStatus.Delivered:
                                        <span class="badge bg-green">تم التسليم</span>
                                        break;
                                    case OrderStatus.Waiting:
                                        <span class="badge bg-orange">مؤجل</span>
                                        break;
                                    case OrderStatus.Rejected:
                                        <span class="badge bg-red">مرفوض</span>
                                        break;
                                    case OrderStatus.Returned:
                                        <span class="badge bg-red-gradient">مرتجع</span>
                                        break;
                                    case OrderStatus.PartialDelivered:
                                        <span class="badge bg-teal">تسليم جزئى</span>
                                        break;
                                    case OrderStatus.PartialReturned:
                                        <span class="badge bg-maroon">مرتجع جزئى</span>
                                        break;
                                    default:
                                        <span class="badge bg-gray">@order.Status</span>
                                        break;
                                }
                            </td>
                            <td>@order.Notes</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        $("#tableDetails").DataTable({
            paging: false,
            ordering: false,
            info: false,
            searching: false
        });
    });

    function exportSheetExcel() {
        var url = '/Orders/ExportSheetExcel?id=@sheet.Id&useCustomColumns=true';
        document.querySelectorAll('.excel-col-option').forEach(function (cb) {
            url += '&' + cb.getAttribute('data-col') + '=' + cb.checked;
        });
        window.location.href = url;
    }
</script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
