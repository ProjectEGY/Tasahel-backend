@model IEnumerable<PostexS.Models.Domain.ApplicationUser>
@{
    ViewData["Title"] = "طلبات انضمام المناديب";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="panel panel-primary">
    <div class="panel-heading">
        <h3 class="panel-title"><i class="fa fa-fw fa-motorcycle"></i> @ViewData["Title"]</h3>
    </div>
    <div class="panel-body">
        <a class="btn btn-default mb-5" href="@Url.Action("Index", "Users", new { q = "d" })">
            <i class="fa fa-arrow-right"></i> العودة للمناديب
        </a>

        @if (!Model.Any())
        {
            <div class="alert alert-info text-center" style="margin-top: 15px;">
                <i class="fa fa-info-circle"></i> لا توجد طلبات انضمام حاليا
            </div>
        }
        else
        {
            <div class="table-responsive" style="margin-top: 15px;">
                <table id="tablePendingDrivers" cellpadding="0" cellspacing="0" border="0" class="table table-striped table-bordered table-hover">
                    <thead>
                        <tr>
                            <th style="text-align:center">#</th>
                            <th style="text-align:center">اسم المندوب</th>
                            <th style="text-align:center">رقم الهاتف</th>
                            <th style="text-align:center">رقم الواتساب</th>
                            <th style="text-align:center">الايميل</th>
                            <th style="text-align:center">العنوان</th>
                            <th style="text-align:center">التحكم</th>
                        </tr>
                    </thead>
                    <tbody style="text-align:center">
                        @{ int counter = 1; }
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@(counter++)</td>
                                <td>@item.Name</td>
                                <td>@item.PhoneNumber</td>
                                <td>@item.WhatsappPhone</td>
                                <td>@item.Email</td>
                                <td>@item.Address</td>
                                <td>
                                    <button type="button" class="btn btn-success btn-sm" onclick="AcceptDriver('@item.Id', '@item.Name')" title="قبول">
                                        <i class="fa fa-check"></i> قبول
                                    </button>
                                    <button type="button" class="btn btn-danger btn-sm" onclick="RejectDriver('@item.Id', '@item.Name')" title="رفض" style="margin-top: 3px;">
                                        <i class="fa fa-times"></i> رفض
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<script>
    $(document).ready(function () {
        $('#tablePendingDrivers').DataTable({
            "pageLength": 25,
            "language": {
                "lengthMenu": "عرض _MENU_ عناصر لكل صفحة",
                "zeroRecords": "لا توجد طلبات انضمام",
                "info": "عرض صفحة _PAGE_ من _PAGES_",
                "infoEmpty": "لا توجد بيانات",
                "infoFiltered": "(تمت التصفية من _MAX_ إجمالي السجلات)",
                "search": "بحث:",
                "paginate": {
                    "next": "التالي",
                    "previous": "السابق"
                }
            }
        });
    });

    function AcceptDriver(userId, userName) {
        swal({
            title: "تأكيد القبول",
            text: "هل تريد قبول طلب انضمام " + userName + "؟",
            icon: "success",
            buttons: ["إلغاء", "قبول"]
        }).then((willAccept) => {
            if (willAccept) {
                window.location.href = '@Url.Action("Accpet", "Users")?UserId=' + userId;
            }
        });
    }

    function RejectDriver(userId, userName) {
        swal({
            title: "تأكيد الرفض",
            text: "هل تريد رفض طلب انضمام " + userName + "؟ سيتم حذف الحساب.",
            icon: "warning",
            dangerMode: true,
            buttons: ["إلغاء", "رفض"]
        }).then((willReject) => {
            if (willReject) {
                $.ajax({
                    type: "Get",
                    url: '/Users/Delete?id=' + userId,
                    success: function (data) {
                        if (data.success) {
                            toastr.success("تم رفض طلب الانضمام بنجاح");
                            setTimeout(function () { location.reload(); }, 1500);
                        } else {
                            toastr.error(data.message || "حدث خطأ");
                        }
                    },
                    error: function () {
                        toastr.error("حدث خطأ في الاتصال بالسيرفر");
                    }
                });
            }
        });
    }
</script>
