@model PostexS.Models.ViewModels.OrdersVM
@{
    ViewBag.Title = "إضافة أكثر من طلب";
}


<div class="panel panel-primary">
    <div class="panel-heading">
        <h3 class="panel-title"><i class="fa fa-fw fa-globe"></i> @ViewBag.Title</h3>
    </div>
    <div class="panel-body">
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger text-center p-5 m-5">
                <ul style="list-style:none;">
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <li>@Html.Raw(error.ErrorMessage)</li>
                    }
                </ul>
            </div>
        }
        <div class="card-body p-5">
            <!-- ============= بانر الإصدار الجديد ============= -->
            <div class="new-version-banner">
                <div class="badge-new">جديد</div>
                <div class="banner-icon"><i class="fas fa-exclamation-circle"></i></div>
                <div class="banner-content">
                    <h4 class="banner-title">⚠️ تحديث مهم على ملف الإكسيل</h4>
                    <p class="banner-desc">
                        تم إضافة عمود جديد: <strong style="background:#fff3cd; padding:2px 8px; border-radius:6px; color:#78350f;">"رقم هاتف إضافي للمرسل إليه"</strong>
                        مكانه بعد عمود رقم الهاتف مباشرة.
                    </p>
                    <ul class="banner-list">
                        <li><i class="fas fa-check-circle text-success"></i> النسخة الجديدة هي <strong>الافتراضية</strong> الآن — حمّل الملف من الزرار بالأسفل</li>
                        <li><i class="fas fa-check-circle text-success"></i> الرقم الإضافي <strong>اختياري</strong> — تقدر تسيب الخانة فاضية عادي</li>
                        <li><i class="fas fa-history text-warning"></i> لو لسه عندك ملفات قديمة (بدون العمود الجديد)، فعّل خيار <strong>"النسخة القديمة"</strong> بالأسفل</li>
                    </ul>

                    <div class="action-row">
                        @using (Html.BeginForm("DownloadFile", "Users", FormMethod.Get))
                        {
                            <button type="submit" class="btn-download-template">
                                <i class="fas fa-file-excel"></i>
                                <span>
                                    <strong>تحميل النموذج الجديد</strong>
                                    <small>10 أعمدة - يشمل الرقم الإضافي</small>
                                </span>
                                <i class="fas fa-arrow-down arrow-anim"></i>
                            </button>
                        }
                        <div class="version-pill">
                            <i class="fas fa-bolt"></i>
                            النسخة المحدثة v2
                        </div>
                    </div>
                </div>
            </div>
            <!-- ============================================== -->

            <!-- نموذج الإضافة -->
            <div class="bg-light p-4 rounded-3 mb-4">
                <h5 class="mb-4 text-dark"><i class="fas fa-file-upload me-2"></i>رفع ملف الطلبات</h5>

                <form asp-action="createOrders" method="post" enctype="multipart/form-data" id="uploadForm">
                    <input asp-for="ClientId" hidden />

                    <div class="row g-3">
                        <!-- حقل الملف -->
                        <div class="col-md-8">
                            <label class="form-label fw-bold">ملف الإكسيل</label>
                            <div class="input-group">
                                <input name="file" id="file" type="file" class="form-control" required
                                       accept=".xls,.xlsx" />
                                <button class="btn btn-primary" type="button" id="validateBtn">
                                    <i class="fas fa-check me-1"></i>تحقق
                                </button>
                            </div>
                            <div class="form-text">يجب أن يكون الملف من نوع XLS أو XLSX</div>
                        </div>

                        <!-- خيار الأكواد -->
                        <div class="col-md-4">
                            <div class="form-check form-switch mt-4 pt-2">
                                <input asp-for="UseUploadedCodes" class="form-check-input"
                                       id="useUploadedCodes" type="checkbox" role="switch">
                                <label asp-for="UseUploadedCodes" class="form-check-label fw-bold">
                                    استخدام الأكواد المرفوعة
                                </label>
                            </div>
                        </div>
                    </div>

                    <!-- خيار: نوع الملف (قديم بدون رقم إضافي / جديد مع رقم إضافي) -->
                    <div class="row g-3 mt-2">
                        <div class="col-12">
                            <div style="background:#fff3cd; border-right:4px solid #f59e0b; padding:14px 18px; border-radius:10px;">
                                <div class="form-check form-switch">
                                    <input asp-for="IsOldFileFormat" class="form-check-input"
                                           id="isOldFileFormat" type="checkbox" role="switch">
                                    <label asp-for="IsOldFileFormat" class="form-check-label fw-bold" style="color:#78350f;">
                                        <i class="fas fa-history me-1"></i>
                                        أنا أرفع ملفاً بالنسخة <u>القديمة</u> (بدون عمود "رقم إضافي للمرسل إليه")
                                    </label>
                                </div>
                                <small class="d-block mt-2" style="color:#78350f;">
                                    <i class="fas fa-info-circle"></i>
                                    <strong>الافتراضي:</strong> الملف الجديد بـ <strong>10 أعمدة</strong> فيها عمود "رقم إضافي للمرسل إليه" بعد رقم الهاتف مباشرة.
                                    <br />
                                    لو لسه شغال على ملفاتك القديمة (9 أعمدة)، فعّل هذا الخيار. الرقم الإضافي ممكن يكون فاضي عادي في الملف الجديد.
                                </small>
                            </div>
                        </div>
                    </div>
                    <!-- زر الإرسال -->
                    <div class="mt-5 text-center">
                        <button type="submit" class="btn btn-success px-5 py-2" id="submitBtn">
                            <span id="btnText"><i class="fas fa-save me-2"></i>إضافة الطلبات</span>
                            <span id="spinner" class="spinner-border spinner-border-sm d-none ms-2" role="status"></span>
                        </button>
                    </div>
                </form>
            </div>

            <!-- ملاحظة إضافية -->
            <div class="alert bg-light-warning border-warning mt-4">
                <div class="d-flex align-items-center">
                    <i class="fas fa-exclamation-circle me-3 fs-4"></i>
                    <div>
                        <p class="mb-0">في حالة أن الراسل لديه ملاحظة أساسية لكل الطلبات، سيتم إضافتها تلقائياً لكل طلب.</p>

                    </div>
                </div>
            </div>
            @Html.ActionLink("العودة", "Index", "Orders", null, new { @class = "btn btn-Primary btn-sm" })
        </div>
    </div>
</div>
@section Scripts {
    <!-- المكتبات المطلوبة -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <script>
            $(document).ready(function () {
                // عرض تنبيه التحديث الجديد عند التحميل (مرة واحدة لكل جلسة)
                if (!sessionStorage.getItem('seenNewExcelV2Notice')) {
                    Swal.fire({
                        title: '🔔 تحديث جديد على ملف الإكسيل',
                        html: '<div class="text-start" dir="rtl" style="font-family:Cairo,Tajawal,Arial,sans-serif;">' +
                              '<p style="font-size:15px;">تم إضافة عمود جديد لملف رفع الطلبات:</p>' +
                              '<div style="background:#fef3c7; border:1.5px solid #f59e0b; border-radius:10px; padding:12px 16px; margin:12px 0; color:#78350f; font-weight:700;">' +
                                '<i class="fas fa-phone"></i> رقم هاتف إضافي للمرسل إليه (اختياري)' +
                              '</div>' +
                              '<ul style="padding-right:20px; font-size:13.5px; line-height:1.9;">' +
                                '<li>📥 <strong>حمّل النموذج الجديد</strong> قبل ما ترفع طلبات.</li>' +
                                '<li>✅ الرقم الإضافي اختياري — تقدر تسيبه فاضي.</li>' +
                                '<li>🕒 لو لسه شغال على ملفاتك القديمة، فعّل خيار "النسخة القديمة".</li>' +
                              '</ul>' +
                              '</div>',
                        icon: 'warning',
                        confirmButtonText: 'فهمت، شكراً',
                        confirmButtonColor: '#16a34a',
                        buttonsStyling: true,
                        customClass: { popup: 'rounded-3' }
                    });
                    sessionStorage.setItem('seenNewExcelV2Notice', '1');
                }

                    // التحقق من الملف قبل الرفع
                    $('#validateBtn').click(function() {
                        const fileInput = $('#file')[0];
                        if (!fileInput.files.length) {
                            showError('يرجى اختيار ملف أولاً');
                            return;
                        }

                        const file = fileInput.files[0];
                        const extension = file.name.split('.').pop().toLowerCase();

                        if (extension !== 'xls' && extension !== 'xlsx') {
                            showError('صيغة الملف غير مدعومة. يرجى اختيار ملف إكسيل (xls أو xlsx)');
                            return;
                        }

                        Swal.fire({
                            title: 'الملف صالح',
                            text: 'يمكنك متابعة عملية رفع الملف',
                            icon: 'success',
                            confirmButtonText: 'حسناً'
                        });
                    });


                    // إدارة عرض الزر أثناء التحميل
                    $('#uploadForm').submit(function() {
                        if ($('#file')[0].files.length) {
                            $('#submitBtn').prop('disabled', true);
                            $('#btnText').html('<i class="fas fa-spinner fa-spin me-2"></i>جاري المعالجة');
                        }
            });
        });
    </script>

    <style>
        /* تخصيصات للنوافذ المنبثقة العربية */
        .rtl-popup {
            direction: rtl;
            text-align: right;
            font-family: 'Tahoma', Arial, sans-serif;
        }

        /* تخصيصات إضافية للواجهة */
        .card {
            border-radius: 0.75rem;
            overflow: hidden;
        }

        .form-control:focus {
            border-color: #86b7fe;
            box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.25);
        }

        #submitBtn {
            transition: all 0.3s ease;
        }

            #submitBtn:hover {
                transform: translateY(-2px);
                box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
            }

        /* ============= New Version Banner ============= */
        .new-version-banner {
            position: relative;
            background: linear-gradient(135deg, #fef3c7 0%, #fde68a 50%, #fbbf24 100%);
            border: 2px solid #f59e0b;
            border-radius: 18px;
            padding: 26px 28px 22px;
            margin-bottom: 28px;
            display: flex;
            align-items: flex-start;
            gap: 18px;
            box-shadow: 0 8px 28px -10px rgba(245, 158, 11, 0.4);
            font-family: 'Cairo', 'Tajawal', Arial, sans-serif;
            overflow: hidden;
        }

            .new-version-banner::before {
                content: '';
                position: absolute;
                top: -50%;
                right: -10%;
                width: 220px;
                height: 220px;
                background: radial-gradient(circle, rgba(255,255,255,0.4), transparent 70%);
                pointer-events: none;
            }

        .badge-new {
            position: absolute;
            top: 14px;
            left: 16px;
            background: linear-gradient(135deg, #ef4444, #b91c1c);
            color: #fff;
            padding: 5px 14px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 800;
            box-shadow: 0 4px 12px -4px rgba(239, 68, 68, 0.6);
            animation: badgePulse 1.8s infinite;
        }

        @@keyframes badgePulse {
            0%, 100% { transform: scale(1); box-shadow: 0 4px 12px -4px rgba(239,68,68,.6); }
            50%      { transform: scale(1.06); box-shadow: 0 6px 18px -4px rgba(239,68,68,.85); }
        }

        .banner-icon {
            flex-shrink: 0;
            width: 60px;
            height: 60px;
            background: #fff;
            border-radius: 50%;
            display: grid;
            place-items: center;
            font-size: 28px;
            color: #d97706;
            box-shadow: 0 4px 14px -4px rgba(0,0,0,0.15);
            margin-top: 4px;
        }

        .banner-content { flex: 1; min-width: 0; position: relative; z-index: 1; }

        .banner-title {
            margin: 0 0 8px;
            font-size: 19px;
            font-weight: 800;
            color: #78350f;
        }

        .banner-desc {
            margin: 0 0 12px;
            font-size: 14.5px;
            color: #78350f;
            line-height: 1.7;
        }

        .banner-list {
            margin: 0 0 18px;
            padding: 0;
            list-style: none;
        }
            .banner-list li {
                padding: 6px 0;
                font-size: 13.5px;
                color: #78350f;
                line-height: 1.6;
                display: flex;
                align-items: flex-start;
                gap: 8px;
            }
            .banner-list li i { margin-top: 4px; flex-shrink: 0; }

        .action-row {
            display: flex;
            gap: 14px;
            align-items: center;
            flex-wrap: wrap;
            margin-top: 12px;
        }

        .btn-download-template {
            background: linear-gradient(135deg, #16a34a, #047857);
            color: #fff;
            border: none;
            padding: 14px 24px;
            border-radius: 12px;
            font-weight: 700;
            font-size: 14px;
            display: inline-flex;
            align-items: center;
            gap: 12px;
            cursor: pointer;
            transition: all 0.25s;
            box-shadow: 0 8px 20px -6px rgba(4, 120, 87, 0.5);
        }
            .btn-download-template:hover {
                transform: translateY(-2px);
                box-shadow: 0 12px 26px -6px rgba(4, 120, 87, 0.65);
            }
            .btn-download-template > i:first-child { font-size: 24px; }
            .btn-download-template span { display: flex; flex-direction: column; align-items: flex-start; line-height: 1.3; }
            .btn-download-template span strong { font-size: 15px; }
            .btn-download-template span small { font-size: 11px; opacity: .9; font-weight: 600; }
            .btn-download-template .arrow-anim { animation: bounceDown 1.4s infinite; }

        @@keyframes bounceDown {
            0%, 100% { transform: translateY(0); }
            50%      { transform: translateY(4px); }
        }

        .version-pill {
            background: rgba(255,255,255,0.9);
            color: #d97706;
            padding: 8px 14px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 800;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            border: 1.5px dashed #f59e0b;
        }

        @@media (max-width: 768px) {
            .new-version-banner { flex-direction: column; padding: 22px; }
            .badge-new { top: 10px; left: 10px; }
            .banner-icon { width: 50px; height: 50px; font-size: 22px; }
        }
    </style>
    }
