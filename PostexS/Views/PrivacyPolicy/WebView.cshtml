@model PostexS.Models.Domain.PrivacyPolicy
@{
    ViewBag.Title = "سياسة الخصوصية";
    Layout = "_MobileLayout";
}

<div class="panel panel-primary">
    <div class="panel-heading">
        <h3 class="panel-title"><i class="fa fa-fw fa-shield-alt"></i> سياسة الخصوصية</h3>
    </div>
    <div class="panel-body">
        <div id="accordion" class="panel-group" aria-multiselectable="true" role="tablist">
            <div class="panel panel-success">
                <div id="collapseOne" class="panel-collapse" role="tabpanel" aria-labelledby="headingOne">
                    <div class="panel-body">
                        @Html.ValidationSummary(false, "", new { @class = "text-danger" })
                        @using (Html.BeginForm())
                        {
                            @Html.HiddenFor(x => x.Id)
                            @Html.AntiForgeryToken()
                            <div width="100%" height="1000px;">
                                @if (ViewBag.lang == "ar")
                                {
                                    @Html.TextAreaFor(model => model.Arabic, 30, 40, new { @class = "form-control", @readonly = "true" })
                                }
                                else
                                {
                                    @Html.TextAreaFor(model => model.English, 30, 40, new { @class = "form-control", @readonly = "true" })
                                }
                            </div>
                            <br />
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
@section Scripts{
    <script src="~/Scripts/tinymce/tinymce.js"></script>
    <script>
        tinymce.init({
            selector: "textarea",
            readonly: 1
        });
    </script>
}
