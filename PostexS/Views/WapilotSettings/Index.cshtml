            // ==========================================
            // WhaStack QR Code Management
            // ==========================================
            var qrPollingInterval = null;
            var statusMonitorInterval = null;
            var currentQrSessionId = null;
            var qrRetryTimeoutHandle = null;
            var qrRetryAttempts = 0;
            var maxQrRetryAttempts = 20; // ~40 seconds with 2s retry interval
            var qrRetryDelayMs = 2000;

            function showQrResult(success, message) {
                var resultDiv = $('#whaStackQrResult');
                resultDiv.removeClass('alert-success alert-danger alert-warning');
                resultDiv.addClass(success ? 'alert-success' : 'alert-danger');
                resultDiv.html('<i class="fa fa-' + (success ? 'check' : 'times') + '"></i> ' + message).show();
            }

            function updateStatusBar(status, phone) {
                var bar = $('#whaStackSessionStatusBar');
                var icon = $('#whaStackStatusIcon');
                var text = $('#whaStackStatusText');
                var phoneSpan = $('#whaStackStatusPhone');

                bar.show();

                var sl = (status || '').toLowerCase();
                if (sl === 'connected' || sl === 'active' || sl === 'online') {
                    bar.removeClass('alert-info alert-danger alert-warning').addClass('alert-success');
                    icon.css('color', '#28a745');
                    text.text('متصل');
                    $('#whaStackDisconnectedAlert').hide();
                    $('#btnReconnectWhaStack').hide();
                } else if (sl === 'disconnected' || sl === 'offline') {
                    bar.removeClass('alert-info alert-success alert-warning').addClass('alert-danger');
                    icon.css('color', '#dc3545');
                    text.text('غير متصل');
                    $('#whaStackDisconnectedAlert').show();
                    $('#btnReconnectWhaStack').show();
                } else if (sl === 'qr_pending' || sl === 'connecting' || sl === 'pending') {
                    bar.removeClass('alert-info alert-success alert-danger').addClass('alert-warning');
                    icon.css('color', '#ffc107');
                    text.text('في انتظار مسح الـ QR Code...');
                    $('#whaStackDisconnectedAlert').hide();
                } else {
                    bar.removeClass('alert-success alert-danger alert-warning').addClass('alert-info');
                    icon.css('color', '#17a2b8');
                    text.text('حالة: ' + (status || 'غير معروف'));
                }

                if (phone) {
                    phoneSpan.text('الرقم: ' + phone).show();
                } else {
                    phoneSpan.hide();
                }
            }

            function startQrPolling(sessionId) {
                stopQrPolling();
                currentQrSessionId = sessionId;

                qrPollingInterval = setInterval(function () {
                    $.post('@Url.Action("GetWhaStackSessionStatus")', { sessionId: sessionId }, function (response) {
                        if (response.success) {
                            updateStatusBar(response.status, response.phoneNumber);

                            var sl = (response.status || '').toLowerCase();
                            if (sl === 'connected' || sl === 'active' || sl === 'online') {
                                stopQrPolling();
                                onSessionConnected(sessionId, response.phoneNumber);
                            }
                        }
                    });
                }, 5000);
            }

            function stopQrPolling() {
                if (qrPollingInterval) {
                    clearInterval(qrPollingInterval);
                    qrPollingInterval = null;
                }
            }

            function stopQrRetry() {
                if (qrRetryTimeoutHandle) {
                    clearTimeout(qrRetryTimeoutHandle);
                    qrRetryTimeoutHandle = null;
                }
            }

            function startStatusMonitor(sessionId) {
                stopStatusMonitor();

                statusMonitorInterval = setInterval(function () {
                    $.post('@Url.Action("GetWhaStackSessionStatus")', { sessionId: sessionId }, function (response) {
                        if (response.success) {
                            updateStatusBar(response.status, response.phoneNumber);

                            var sl = (response.status || '').toLowerCase();
                            if (sl === 'disconnected' || sl === 'offline') {
                                $('#whaStackConnectedBox').hide();
                                $('#whaStackQrContainer').hide();
                                currentQrSessionId = sessionId;
                            }
                        }
                    });
                }, 30000);
            }

            function stopStatusMonitor() {
                if (statusMonitorInterval) {
                    clearInterval(statusMonitorInterval);
                    statusMonitorInterval = null;
                }
            }

            function onSessionConnected(sessionId, phone) {
                $.post('@Url.Action("SaveWhaStackSessionId")', { sessionId: sessionId }, function (response) {
                    if (response.success) {
                        $('#WhaStackSettings_SessionId').val(sessionId);
                        showQrResult(true, response.message);
                    } else {
                        showQrResult(false, response.message);
                    }
                });

                $('#whaStackQrContainer').hide();
                $('#whaStackConnectedBox').show();
                $('#whaStackConnectedPhone').text(phone || sessionId);
                $('#whaStackDisconnectedAlert').hide();
                $('#btnReconnectWhaStack').hide();

                startStatusMonitor(sessionId);
            }

            function loadQrCode(sessionId) {
                stopQrRetry();
                $('#whaStackQrContainer').show();
                $('#whaStackConnectedBox').hide();
                $('#whaStackQrImg').hide();
                $('#whaStackQrLoading').show();

                $.post('@Url.Action("GetWhaStackSessionQr")', { sessionId: sessionId }, function (response) {
                    $('#whaStackQrLoading').hide();
                    if (response.success && response.qrCode) {
                        qrRetryAttempts = 0;
                        var src = response.qrCode;
                        if (!src.startsWith('data:')) {
                            if (src.startsWith('http')) {
                                // Direct URL
                            } else {
                                src = 'data:image/png;base64,' + src;
                            }
                        }
                        $('#whaStackQrImg').attr('src', src).show();
                        showQrResult(true, 'تم تحميل الـ QR Code - امسحه بواسطة واتساب');
                        startQrPolling(sessionId);
                    } else if (response.pending) {
                        qrRetryAttempts++;
                        if (qrRetryAttempts <= maxQrRetryAttempts) {
                            showQrResult(true, 'جاري تجهيز الـ QR Code... محاولة ' + qrRetryAttempts + ' من ' + maxQrRetryAttempts);
                            $('#whaStackQrLoading').show();
                            qrRetryTimeoutHandle = setTimeout(function () {
                                loadQrCode(sessionId);
                            }, qrRetryDelayMs);
                        } else {
                            showQrResult(false, 'تأخر تحميل الـ QR Code. اضغط "إعادة الاتصال" أو أعد إنشاء الجلسة.');
                            qrRetryAttempts = 0;
                        }
                    } else {
                        qrRetryAttempts = 0;
                        showQrResult(false, response.message || 'فشل تحميل الـ QR Code');
                    }
                }).fail(function () {
                    $('#whaStackQrLoading').hide();
                    qrRetryAttempts = 0;
                    showQrResult(false, 'حدث خطأ أثناء تحميل الـ QR Code');
                });
            }

            // Create New Session
            $('#btnCreateWhaStackSession').click(function () {
                var btn = $(this);
                var originalHtml = btn.html();
                var name = $('#whaStackNewSessionName').val().trim();

                btn.prop('disabled', true).html('<i class="fa fa-spinner fa-spin"></i> جاري الإنشاء...');
                stopQrPolling();
                stopQrRetry();
                stopStatusMonitor();
                qrRetryAttempts = 0;

                $.post('@Url.Action("CreateWhaStackSession")', { name: name }, function (response) {
                    if (response.success && response.sessionId) {
                        showQrResult(true, response.message);
                        loadQrCode(response.sessionId);
                    } else {
                        showQrResult(false, response.message || 'فشل إنشاء الجلسة');
                    }
                    btn.prop('disabled', false).html(originalHtml);
                }).fail(function () {
                    showQrResult(false, 'حدث خطأ أثناء إنشاء الجلسة - تأكد من ادخال الـ API Key وحفظ الاعدادات أولاً');
                    btn.prop('disabled', false).html(originalHtml);
                });
            });

            // Reconnect Session
            $('#btnReconnectWhaStack').click(function () {
                var btn = $(this);
                var originalHtml = btn.html();
                var sessionId = currentQrSessionId || $('#WhaStackSettings_SessionId').val();

                if (!sessionId) {
                    showQrResult(false, 'لا يوجد Session ID للاتصال - أنشئ جلسة جديدة أولاً');
                    return;
                }

                btn.prop('disabled', true).html('<i class="fa fa-spinner fa-spin"></i> جاري إعادة الاتصال...');
                stopQrRetry();
                qrRetryAttempts = 0;
                stopStatusMonitor();

                $.post('@Url.Action("ReconnectWhaStackSession")', { sessionId: sessionId }, function (response) {
                    if (response.success) {
                        showQrResult(true, response.message);
                        loadQrCode(sessionId);
                    } else {
                        showQrResult(false, response.message || 'فشل إعادة الاتصال');
                    }
                    btn.prop('disabled', false).html(originalHtml);
                }).fail(function () {
                    showQrResult(false, 'حدث خطأ أثناء إعادة الاتصال');
                    btn.prop('disabled', false).html(originalHtml);
                });
            });

            // Check Status manually
            $('#btnCheckWhaStackStatus').click(function () {
                var btn = $(this);
                var originalHtml = btn.html();
                var sessionId = currentQrSessionId || $('#WhaStackSettings_SessionId').val();

                if (!sessionId) {
                    showQrResult(false, 'لا يوجد Session ID - أنشئ جلسة جديدة أو اختر جلسة من القائمة');
                    return;
                }

                btn.prop('disabled', true).html('<i class="fa fa-spinner fa-spin"></i> جاري الفحص...');

                $.post('@Url.Action("GetWhaStackSessionStatus")', { sessionId: sessionId }, function (response) {
                    if (response.success) {
                        updateStatusBar(response.status, response.phoneNumber);

                        var sl = (response.status || '').toLowerCase();
                        if (sl === 'connected' || sl === 'active' || sl === 'online') {
                            onSessionConnected(sessionId, response.phoneNumber);
                        }
                        showQrResult(true, response.message);
                    } else {
                        showQrResult(false, response.message || 'فشل فحص الحالة');
                    }
                    btn.prop('disabled', false).html(originalHtml);
                }).fail(function () {
                    showQrResult(false, 'حدث خطأ أثناء فحص الحالة');
                    btn.prop('disabled', false).html(originalHtml);
                });
            });

            // Auto-check status on page load if session ID exists
            var initialSessionId = '@(Model.WhaStackSettings?.SessionId ?? "")';
            if (initialSessionId) {
                $.post('@Url.Action("GetWhaStackSessionStatus")', { sessionId: initialSessionId }, function (response) {
                    if (response.success) {
                        currentQrSessionId = initialSessionId;
                        updateStatusBar(response.status, response.phoneNumber);

                        var sl = (response.status || '').toLowerCase();
                        if (sl === 'connected' || sl === 'active' || sl === 'online') {
                            startStatusMonitor(initialSessionId);
                        }
                    }
                });
            }

            function showResult(provider, success, message) {
                var resultDiv = provider === 'wapilot' ? $('#wapilotTestResult') :
                               provider === 'botCloud' ? $('#botCloudTestResult') :
                               provider === 'whaStack' ? $('#whaStackTestResult') :
                               provider === 'background' ? $('#backgroundTestResult') :
                               $('#providerResult');
                resultDiv.removeClass('alert-success alert-danger');
                resultDiv.addClass(success ? 'alert-success' : 'alert-danger');
                resultDiv.html('<i class="fa fa-' + (success ? 'check' : 'times') + '"></i> ' + message).show();
            }
        });
    </script>
}
