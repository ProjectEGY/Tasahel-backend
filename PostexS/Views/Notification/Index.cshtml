@{
    ViewData["Title"] = "إرسال الإشعارات";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var isHighAdmin = (bool)ViewBag.IsHighAdmin;
    var currentBranchId = (long)ViewBag.CurrentBranchId;
}

<div class="panel panel-primary">
    <div class="panel-heading">
        <h3 class="panel-title"><i class="fa fa-fw fa-bullhorn"></i> @ViewData["Title"]</h3>
    </div>
    <div class="panel-body">

        @if (TempData["SentSuccess"] != null)
        {
            <div class="alert alert-success text-center" style="margin-bottom: 15px;">
                <i class="fa fa-check-circle"></i> تم إرسال الإشعار بنجاح
            </div>
        }
        @if (TempData["SentError"] != null)
        {
            <div class="alert alert-danger text-center" style="margin-bottom: 15px;">
                <i class="fa fa-exclamation-circle"></i> برجاء التأكد من صحة المدخلات (العنوان والمحتوى مطلوبين)
            </div>
        }

        <div class="alert alert-warning" style="margin-bottom: 20px;">
            <i class="fa fa-info-circle"></i>
            برجاء عدم غلق الصفحة عند إرسال الإشعار حيث أنه من الممكن أن يستغرق الإرسال بعض الدقائق.
        </div>

        <!-- تبويبات المناديب والراسلين -->
        <ul class="nav nav-tabs" role="tablist" style="margin-bottom: 20px;">
            <li role="presentation" class="active">
                <a href="#tab-drivers" aria-controls="tab-drivers" role="tab" data-toggle="tab">
                    <i class="fa fa-motorcycle"></i> إرسال للمناديب
                </a>
            </li>
            <li role="presentation">
                <a href="#tab-clients" aria-controls="tab-clients" role="tab" data-toggle="tab">
                    <i class="fa fa-user"></i> إرسال للراسلين
                </a>
            </li>
        </ul>

        <div class="tab-content">
            <!-- تبويب المناديب -->
            <div role="tabpanel" class="tab-pane active" id="tab-drivers">
                @using (Html.BeginForm("Create", "Notification", FormMethod.Post))
                {
                    <input type="hidden" name="targetType" value="driver" />
                    <div class="row" style="margin-bottom: 15px;">
                        @if (!isHighAdmin)
                        {
                            <div class="col-md-4">
                                <label><i class="fa fa-home"></i> فلتر بالفرع:</label>
                                <select id="driverBranchFilter" class="form-control select2" style="width:100%">
                                    <option value="0">كل الفروع</option>
                                    @foreach (SelectListItem item in (SelectList)ViewBag.Branches)
                                    {
                                        <option value="@item.Value">@item.Text</option>
                                    }
                                </select>
                            </div>
                        }
                        <div class="@(isHighAdmin ? "col-md-12" : "col-md-8")">
                            <label><i class="fa fa-users"></i> اختيار المناديب: <small class="text-muted">(اتركه فارغ للإرسال لجميع المناديب)</small></label>
                            <select name="Users" id="driverUsers" class="form-control" multiple style="width:100%"></select>
                        </div>
                    </div>
                    <div class="row" style="margin-bottom: 15px;">
                        <div class="col-md-12">
                            <label class="required"><i class="fa fa-tag"></i> عنوان الإشعار:</label>
                            <input name="Title" type="text" required class="form-control" placeholder="أدخل عنوان الإشعار" />
                        </div>
                    </div>
                    <div class="row" style="margin-bottom: 15px;">
                        <div class="col-md-12">
                            <label class="required"><i class="fa fa-align-right"></i> محتوى الإشعار:</label>
                            <textarea name="Body" required class="form-control" rows="5" placeholder="أدخل محتوى الإشعار"></textarea>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-success btn-lg">
                        <i class="fa fa-paper-plane"></i> إرسال الإشعار للمناديب
                    </button>
                }
            </div>

            <!-- تبويب الراسلين -->
            <div role="tabpanel" class="tab-pane" id="tab-clients">
                @using (Html.BeginForm("Create", "Notification", FormMethod.Post))
                {
                    <input type="hidden" name="targetType" value="client" />
                    <div class="row" style="margin-bottom: 15px;">
                        @if (!isHighAdmin)
                        {
                            <div class="col-md-4">
                                <label><i class="fa fa-home"></i> فلتر بالفرع:</label>
                                <select id="clientBranchFilter" class="form-control select2" style="width:100%">
                                    <option value="0">كل الفروع</option>
                                    @foreach (SelectListItem item in (SelectList)ViewBag.Branches)
                                    {
                                        <option value="@item.Value">@item.Text</option>
                                    }
                                </select>
                            </div>
                        }
                        <div class="@(isHighAdmin ? "col-md-12" : "col-md-8")">
                            <label><i class="fa fa-users"></i> اختيار الراسلين: <small class="text-muted">(اتركه فارغ للإرسال لجميع الراسلين)</small></label>
                            <select name="Users" id="clientUsers" class="form-control" multiple style="width:100%"></select>
                        </div>
                    </div>
                    <div class="row" style="margin-bottom: 15px;">
                        <div class="col-md-12">
                            <label class="required"><i class="fa fa-tag"></i> عنوان الإشعار:</label>
                            <input name="Title" type="text" required class="form-control" placeholder="أدخل عنوان الإشعار" />
                        </div>
                    </div>
                    <div class="row" style="margin-bottom: 15px;">
                        <div class="col-md-12">
                            <label class="required"><i class="fa fa-align-right"></i> محتوى الإشعار:</label>
                            <textarea name="Body" required class="form-control" rows="5" placeholder="أدخل محتوى الإشعار"></textarea>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary btn-lg">
                        <i class="fa fa-paper-plane"></i> إرسال الإشعار للراسلين
                    </button>
                }
            </div>
        </div>

    </div>
</div>

@section scripts {
<script>
    var defaultBranchId = @(isHighAdmin ? currentBranchId.ToString() : "0");

    function initUserSelect(selectId, userType, branchFilterId) {
        var branchId = branchFilterId ? ($('#' + branchFilterId).val() || defaultBranchId) : defaultBranchId;

        $('#' + selectId).select2({
            placeholder: 'ابحث بالاسم أو رقم الهاتف...',
            allowClear: true,
            minimumInputLength: 0,
            ajax: {
                url: '@Url.Action("SearchUsers", "Notification")',
                dataType: 'json',
                delay: 300,
                data: function (params) {
                    var bId = branchFilterId ? ($('#' + branchFilterId).val() || defaultBranchId) : defaultBranchId;
                    return {
                        term: params.term || '',
                        branchId: bId,
                        userType: userType
                    };
                },
                processResults: function (data) {
                    return { results: data.results };
                }
            }
        });

        // عند تغيير الفرع، امسح الاختيارات السابقة وأعد التحميل
        if (branchFilterId) {
            $('#' + branchFilterId).on('change', function () {
                $('#' + selectId).val(null).trigger('change');
            });
        }
    }

    $(document).ready(function () {
        initUserSelect('driverUsers', 'driver', @(isHighAdmin ? "null" : "'driverBranchFilter'"));
        initUserSelect('clientUsers', 'client', @(isHighAdmin ? "null" : "'clientBranchFilter'"));
    });
</script>
}
