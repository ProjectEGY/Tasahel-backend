@*
    سكانر الباركود لطلبات المندوبين/التحويلات بين الفروع.
    يفترض إن في الصفحة <select id="Orders" multiple> فيه كل الطلبات المتاحة كـ <option value="OrderId">OrderCode</option>.
    يضيف:
      - حقل سكان باركود مع debouncing وكشف تلقائي
      - جدول مباشر للطلبات المضافة (مزامنة مع الـ select)
      - تنبيه + صوت لو الطلب مكرر، أو مش موجود في القائمة، أو نجاح
    استخدمه بـ:  @Html.Partial("_OrderBarcodeScanner")
*@
<style>
    .ord-scan-wrap { font-family: 'Cairo', 'Tajawal', sans-serif; margin: 16px 0; }
    .ord-scan-input {
        width: 100%; padding: 14px 16px; border: 2px solid #28a745; border-radius: 10px;
        font-size: 17px; font-weight: 600; outline: none; transition: border-color .2s, box-shadow .2s;
        font-family: inherit; background: #fff;
    }
    .ord-scan-input:focus { border-color: #16a34a; box-shadow: 0 0 0 4px rgba(40,167,69,.15); }
    .ord-scan-feedback { display: block; min-height: 22px; margin-top: 8px; font-weight: 700; font-size: 13.5px; }
    .ord-scan-label { font-weight: 700; font-size: 14px; color: #1f2937; margin-bottom: 8px; display: block; }
    .ord-scan-label .fa { color: #28a745; }

    .ord-table-wrap {
        max-height: 320px; overflow-y: auto; border: 1px solid #e5e7eb; border-radius: 10px; margin-top: 8px;
        background: #fff;
    }
    .ord-table { width: 100%; border-collapse: separate; border-spacing: 0; margin: 0; }
    .ord-table thead th {
        background: #34495e; color: #fff; font-weight: 700; font-size: 13px;
        padding: 12px; text-align: center; position: sticky; top: 0; z-index: 1;
    }
    .ord-table tbody td { padding: 11px 12px; border-bottom: 1px solid #f1f5f9; text-align: center; font-size: 14px; vertical-align: middle; }
    .ord-table tbody tr:hover { background: #fafbfd; }
    .ord-table tbody tr:last-child td { border-bottom: none; }
    .ord-table .empty-row td { text-align: center; padding: 28px; color: #94a3b8; }

    .ord-rm-btn {
        background: #ef4444; color: #fff; border: none; padding: 5px 12px;
        border-radius: 6px; font-size: 12px; font-weight: 600; cursor: pointer;
        display: inline-flex; align-items: center; gap: 4px;
    }
    .ord-rm-btn:hover { background: #dc2626; }

    .ord-count-badge {
        background: #28a745; color: #fff; padding: 2px 10px; border-radius: 12px;
        font-size: 12px; font-weight: 700; margin-right: 6px;
    }
</style>

<div class="ord-scan-wrap">
    <label for="barcodeScanner" class="ord-scan-label">
        <i class="fa fa-barcode"></i> امسح كود الطلب بالباركود:
    </label>
    <input type="text" id="barcodeScanner" class="ord-scan-input" autocomplete="off"
           placeholder="ضع المؤشر هنا وامسح الباركود..." autofocus />
    <small id="scanFeedback" class="ord-scan-feedback"></small>
</div>

<div class="ord-scan-wrap">
    <label class="ord-scan-label">
        <i class="fa fa-list"></i> الطلبات المضافة <span class="ord-count-badge" id="addedOrdersCount">0</span>
    </label>
    <div class="ord-table-wrap">
        <table class="ord-table" id="addedOrdersTable">
            <thead>
                <tr>
                    <th style="width:60px;">#</th>
                    <th>كود الطلب</th>
                    <th style="width:120px;">إجراء</th>
                </tr>
            </thead>
            <tbody id="addedOrdersBody">
                <tr class="empty-row" id="emptyRow">
                    <td colspan="3">لا توجد طلبات مضافة بعد — امسح باركود أو اختر من القائمة.</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<script>
    (function () {
        // الانتظار لحد ما jQuery و select2 يكونوا جاهزين
        function ready() { if (typeof jQuery === 'undefined') { return setTimeout(ready, 50); } init(jQuery); }

        function init($) {
            $(function () {
                if ($('#Orders').length === 0) return; // مفيش select Orders في الصفحة دي

                function findOrderOptionByCode(code) {
                    code = (code || '').trim().toLowerCase();
                    if (!code) return null;
                    var match = null;
                    $('#Orders option').each(function () {
                        var txt = $(this).text().trim().toLowerCase();
                        // الـ text ممكن يكون "ES7896 - 100 جنية" - نقارن بأول جزء قبل أي فاصل
                        var first = txt.split(' ')[0].split('-')[0].trim();
                        if (first === code || txt === code) { match = $(this); return false; }
                    });
                    return match;
                }

                function playBeep(freq, duration) {
                    try {
                        var ctx = new (window.AudioContext || window.webkitAudioContext)();
                        var osc = ctx.createOscillator();
                        var gain = ctx.createGain();
                        osc.connect(gain); gain.connect(ctx.destination);
                        osc.frequency.value = freq; osc.type = 'sine';
                        gain.gain.setValueAtTime(0.15, ctx.currentTime);
                        osc.start(); osc.stop(ctx.currentTime + duration);
                    } catch (ex) { }
                }

                function setFeedback(msg, color) {
                    $('#scanFeedback').text(msg).css('color', color);
                    $('#barcodeScanner').css('border-color', color);
                    setTimeout(function () { $('#barcodeScanner').css('border-color', '#28a745'); }, 1500);
                }

                function flashRow(code) {
                    var $row = $('#addedOrdersBody tr[data-code="' + code.toLowerCase() + '"]');
                    if ($row.length) {
                        $row.css({ 'background-color': '#fee2e2', 'transition': 'background-color .5s' });
                        $row[0].scrollIntoView({ behavior: 'smooth', block: 'center' });
                        setTimeout(function () { $row.css('background-color', ''); }, 1500);
                    }
                }

                function showDuplicateAlert(code) {
                    playBeep(220, 0.3);
                    setFeedback('⚠ الطلب "' + code + '" موجود بالفعل في القائمة!', '#dc3545');
                    flashRow(code);
                    if (typeof swal === 'function') {
                        swal({ title: 'طلب مكرر!', text: 'الطلب رقم "' + code + '" تم مسحه من قبل.', icon: 'warning', button: 'حسناً' });
                    }
                }
                function showNotFoundAlert(code) {
                    playBeep(180, 0.4);
                    setFeedback('✗ الكود "' + code + '" غير موجود في الطلبات المتاحة!', '#dc3545');
                }
                function showSuccessFeedback(code) {
                    playBeep(880, 0.1);
                    setFeedback('✓ تمت إضافة الطلب "' + code + '"', '#28a745');
                }

                function rebuildTable() {
                    var $body = $('#addedOrdersBody');
                    $body.empty();
                    var $selected = $('#Orders option:selected');
                    $('#addedOrdersCount').text($selected.length);
                    if ($selected.length === 0) {
                        $body.append('<tr class="empty-row"><td colspan="3">لا توجد طلبات مضافة بعد — امسح باركود أو اختر من القائمة.</td></tr>');
                        return;
                    }
                    $selected.each(function (i) {
                        var id = $(this).val();
                        var fullText = $(this).text().trim();
                        var code = fullText.split(' ')[0].split('-')[0].trim();
                        var row = '<tr data-id="' + id + '" data-code="' + code.toLowerCase() + '">' +
                            '<td>' + (i + 1) + '</td>' +
                            '<td><strong>' + fullText + '</strong></td>' +
                            '<td><button type="button" class="ord-rm-btn" data-id="' + id + '"><i class="fa fa-trash"></i> حذف</button></td>' +
                        '</tr>';
                        $body.append(row);
                    });
                }

                // حذف من الجدول → unselect من select2
                $(document).on('click', '.ord-rm-btn', function () {
                    var id = $(this).data('id');
                    var $opt = $('#Orders option[value="' + id + '"]');
                    $opt.prop('selected', false);
                    $('#Orders').trigger('change');
                });

                function processScannedCode() {
                    var $input = $('#barcodeScanner');
                    var code = $input.val().trim();
                    $input.val('');
                    if (!code) return;

                    var $opt = findOrderOptionByCode(code);
                    if (!$opt) { showNotFoundAlert(code); return; }
                    if ($opt.is(':selected')) { showDuplicateAlert($opt.text().split(' ')[0].split('-')[0].trim()); return; }
                    $opt.prop('selected', true);
                    $('#Orders').trigger('change');
                    showSuccessFeedback($opt.text().split(' ')[0].split('-')[0].trim());
                }

                $('#barcodeScanner').on('keydown', function (e) {
                    if (e.key === 'Enter' || e.keyCode === 13) {
                        e.preventDefault();
                        if (scanTimer) { clearTimeout(scanTimer); scanTimer = null; }
                        processScannedCode();
                    }
                });

                var scanTimer = null;
                $('#barcodeScanner').on('input', function () {
                    if (scanTimer) clearTimeout(scanTimer);
                    var val = $(this).val().trim();
                    if (val.length < 3) return;
                    scanTimer = setTimeout(function () { scanTimer = null; processScannedCode(); }, 150);
                });

                // الحفاظ على التركيز
                $('#barcodeScanner').on('blur', function () {
                    var $self = $(this);
                    setTimeout(function () {
                        var a = document.activeElement;
                        if (a && (a.classList.contains('select2-search__field') || a.tagName === 'BUTTON' || a.tagName === 'INPUT' || a.tagName === 'SELECT' || a.tagName === 'TEXTAREA')) return;
                        $self.focus();
                    }, 100);
                });

                // مزامنة select2 مع الجدول
                $('#Orders').on('change', rebuildTable);

                // كشف التكرار من select2 يدوي
                var addedIds = {};
                $('#Orders option:selected').each(function () { addedIds[$(this).val()] = true; });
                $('#Orders').on('select2:select', function (e) {
                    var id = e.params.data.id;
                    if (addedIds[id]) {
                        var txt = e.params.data.text || '';
                        showDuplicateAlert(txt.split(' ')[0].split('-')[0].trim());
                    } else { addedIds[id] = true; }
                });
                $('#Orders').on('select2:unselect', function (e) { delete addedIds[e.params.data.id]; });

                rebuildTable();
                setTimeout(function () { $('#barcodeScanner').focus(); }, 200);
            });
        }
        ready();
    })();
</script>
