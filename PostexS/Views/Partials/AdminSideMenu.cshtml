@model PostexS.Models.ViewModels.SideMenuVM
@using System
@using System.Linq
@using System.Security.Claims
@inject PostexS.Models.Data.ApplicationDbContext _empTrCtx
@{
    var currentUserId = User?.FindFirstValue(ClaimTypes.NameIdentifier) ?? string.Empty;
    var currentUserEmail = User?.FindFirstValue(ClaimTypes.Email) ?? User?.Identity?.Name ?? string.Empty;
    var canSeeSenderTransferTab =
        User.IsInRole("Admin") &&
        (
            string.Equals(currentUserEmail, "Admin@Tasahel.com", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(currentUserEmail, "elyaskee@Tasahel.com", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(currentUserId, "9897454b-add0-45ef-ad3b-53027814ede", StringComparison.OrdinalIgnoreCase)
        );

    // ===== لينكات تحويلات الموظفين =====
    const string MainAdminUserId = "9897454b-add0-45ef-ad3b-53027814ede7";
    bool isMainAdmin = string.Equals(currentUserId, MainAdminUserId, StringComparison.OrdinalIgnoreCase);
    bool canSubmitTransfer = User.IsInRole("Accountant") || User.IsInRole("HighAdmin");
    int pendingTransfersCount = 0;
    int myPendingCount = 0;
    if (isMainAdmin)
    {
        pendingTransfersCount = _empTrCtx.EmployeeMoneyTransferRequests
            .Count(x => !x.IsDeleted && x.Status == PostexS.Models.Enums.TransferRequestStatus.Pending);
    }
    if (canSubmitTransfer && !isMainAdmin)
    {
        myPendingCount = _empTrCtx.EmployeeMoneyTransferRequests
            .Count(x => !x.IsDeleted && x.EmployeeUserId == currentUserId
                        && x.Status == PostexS.Models.Enums.TransferRequestStatus.Pending);
    }
}
<aside class="main-sidebar">
