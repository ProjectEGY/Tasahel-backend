@model PostexS.Models.Domain.WhaStackSessionInstance
@{
    ViewData["Title"] = "إضافة جلسة واتساب جديدة";
}

<style>
    .ws-page { font-family: 'Cairo', 'Tajawal', sans-serif; padding: 24px; background: #f5f7fb; min-height: 100vh; }

    .ws-form-hero {
        background: linear-gradient(135deg, #25D366 0%, #128C7E 100%);
        color: #fff; padding: 28px 32px; border-radius: 18px 18px 0 0;
        display: flex; align-items: center; gap: 16px;
    }
    .ws-form-hero .icon-wrap {
        width: 56px; height: 56px; background: rgba(255,255,255,.2); border-radius: 14px;
        display: grid; place-items: center; font-size: 24px;
    }
    .ws-form-hero h1 { margin: 0; font-size: 22px; font-weight: 700; }
    .ws-form-hero p  { margin: 4px 0 0; opacity: .92; font-size: 14px; }

    .ws-form-card {
        background: #fff; border-radius: 0 0 18px 18px; padding: 32px;
        box-shadow: 0 8px 28px -12px rgba(15,23,42,.15); margin-bottom: 22px; max-width: 1000px;
    }

    /* Steps indicator */
    .steps-bar { display: flex; gap: 8px; margin-bottom: 26px; }
    .step {
        flex: 1; padding: 14px 18px; border-radius: 12px; background: #f1f5f9; color: #94a3b8;
        font-weight: 700; font-size: 13px; display: flex; align-items: center; gap: 10px;
        transition: all .3s; border: 2px solid transparent;
    }
    .step .step-num {
        width: 26px; height: 26px; border-radius: 50%; background: #cbd5e1; color: #fff;
        display: grid; place-items: center; font-size: 13px; flex-shrink: 0;
    }
    .step.active { background: #ecfdf5; color: #166534; border-color: #25D366; }
    .step.active .step-num { background: #25D366; }
    .step.done { background: #fff; color: #16a34a; }
    .step.done .step-num { background: #16a34a; }

    .form-row { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; margin-bottom: 18px; }
    .form-field label { display: block; font-size: 13px; font-weight: 700; color: #334155; margin-bottom: 8px; }
    .form-field label .req { color: #ef4444; margin-right: 3px; }
    .form-field .form-control {
        width: 100%; padding: 12px 14px; border-radius: 10px;
        border: 1.5px solid #e2e8f0; background: #fff; font-size: 14px;
        transition: all .2s; font-family: inherit;
    }
    .form-field .form-control:focus {
        outline: none; border-color: #25D366; box-shadow: 0 0 0 4px rgba(37,211,102,.12);
    }
    .form-field .form-control:disabled { background: #f8fafc; color: #64748b; }
    .form-field .hint { font-size: 12px; color: #94a3b8; margin-top: 6px; line-height: 1.6; }

    .ws-banner-info {
        background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
        border-right: 4px solid #f59e0b;
        padding: 14px 18px; border-radius: 12px; margin-bottom: 22px;
        color: #78350f; font-size: 13px; line-height: 1.7;
    }
    .ws-banner-info i { color: #f59e0b; margin-left: 6px; }

    .form-actions {
        display: flex; gap: 12px; justify-content: flex-end;
        padding-top: 22px; border-top: 1px solid #f1f5f9; margin-top: 8px;
    }
    .ws-btn {
        display: inline-flex; align-items: center; gap: 8px; padding: 11px 22px;
        border-radius: 10px; font-size: 14px; font-weight: 700; border: none;
        cursor: pointer; transition: all .25s; text-decoration: none;
    }
    .ws-btn-primary {
        background: linear-gradient(135deg,#25D366,#128C7E); color: #fff;
        box-shadow: 0 6px 18px -8px rgba(18,140,126,.5);
    }
    .ws-btn-primary:hover { transform: translateY(-2px); color: #fff; }
    .ws-btn-primary:disabled { opacity: .6; transform: none; cursor: not-allowed; }
    .ws-btn-cancel { background: #f1f5f9; color: #475569; }
    .ws-btn-cancel:hover { background: #e2e8f0; color: #334155; }

    /* QR section */
    .qr-section {
        display: grid; grid-template-columns: 1fr 1.2fr; gap: 28px; align-items: start;
        margin-top: 8px;
    }
    .qr-card {
        background: linear-gradient(180deg, #f0fdf4 0%, #ffffff 100%);
        border: 2px dashed #25D366; border-radius: 18px; padding: 24px; text-align: center;
        min-height: 360px;
    }
    .qr-card h4 { color: #128C7E; margin: 0 0 14px; font-weight: 700; font-size: 16px; }
    .qr-card .qr-img-wrap {
        background: #fff; padding: 16px; border-radius: 14px; display: inline-block;
        box-shadow: 0 4px 18px -8px rgba(15,23,42,.15);
    }
    .qr-card img { max-width: 280px; max-height: 280px; display: block; }
    .qr-card .qr-loading {
        padding: 60px 20px; color: #25D366;
    }
    .qr-card .qr-loading i { font-size: 40px; margin-bottom: 14px; }
    .qr-card .qr-loading p { color: #128C7E; font-weight: 600; margin: 0; }
    .qr-card .qr-instructions {
        margin-top: 16px; font-size: 12px; color: #475569; line-height: 1.8;
        background: #fff; padding: 10px 14px; border-radius: 8px;
    }

    .session-info {
        background: #f8fafc; border-radius: 14px; padding: 20px;
    }
    .session-info h4 { margin: 0 0 14px; color: #0f172a; font-weight: 700; font-size: 16px; }
    .session-info .info-row { display: flex; justify-content: space-between; padding: 10px 0; border-bottom: 1px solid #e2e8f0; }
    .session-info .info-row:last-child { border-bottom: none; }
    .session-info .info-row .key { color: #64748b; font-size: 13px; font-weight: 600; }
    .session-info .info-row .val { color: #0f172a; font-size: 13px; font-weight: 700; font-family: 'Courier New', monospace; }

    .status-card {
        background: #fff; border: 1px solid #e2e8f0; border-radius: 14px; padding: 16px 20px;
        margin-top: 14px; display: flex; align-items: center; gap: 12px; transition: all .3s;
    }
    .status-card.connecting { border-color: #fbbf24; background: #fffbeb; }
    .status-card.connected  { border-color: #25D366; background: #ecfdf5; }
    .status-card.failed     { border-color: #ef4444; background: #fef2f2; }
    .status-card .status-icon { font-size: 24px; }
    .status-card.connecting .status-icon { color: #f59e0b; }
    .status-card.connected  .status-icon { color: #16a34a; }
    .status-card.failed     .status-icon { color: #dc2626; }
    .status-card strong { font-size: 14px; display: block; color: #0f172a; }
    .status-card small  { font-size: 12px; color: #64748b; }

    @@keyframes pulse-ring { 0% { transform: scale(.95); opacity: .9; } 50% { transform: scale(1.05); opacity: 1; } 100% { transform: scale(.95); opacity: .9; } }
    .pulse { animation: pulse-ring 1.5s ease-in-out infinite; }

    @@media (max-width: 768px) {
        .qr-section { grid-template-columns: 1fr; }
    }

    .toast-msg {
        padding: 12px 16px; border-radius: 10px; font-weight: 600; font-size: 13px; margin-bottom: 14px;
    }
    .toast-msg.ok  { background: #dcfce7; color: #166534; border-right: 4px solid #16a34a; }
    .toast-msg.err { background: #fee2e2; color: #991b1b; border-right: 4px solid #dc2626; }
</style>

<div class="ws-page">
    <div class="ws-form-hero">
        <div class="icon-wrap"><i class="fa fa-plus"></i></div>
        <div>
            <h1>@ViewData["Title"]</h1>
            <p>أنشئ جلسة جديدة لرقم واتساب — هتنشئ جلسة في WhaStack ثم تمسح QR لربط الرقم.</p>
        </div>
    </div>

    <div class="ws-form-card">
        <!-- Steps indicator -->
        <div class="steps-bar">
            <div class="step active" id="step1"><span class="step-num">1</span> بيانات الجلسة</div>
            <div class="step" id="step2"><span class="step-num">2</span> مسح QR Code</div>
            <div class="step" id="step3"><span class="step-num">3</span> تم الربط</div>
        </div>

        <div id="formMessage"></div>

        <!-- ====== Step 1: Form ====== -->
        <div id="stage1">
            <div class="ws-banner-info">
                <i class="fa fa-info-circle"></i>
                <strong>كيف يشتغل؟</strong>
                هتدخل اسم وصفي للجلسة ورقم الهاتف (اختياري) وتضغط "إنشاء". هيتم استدعاء WhaStack تلقائياً لإنشاء الجلسة، ثم يظهر QR Code، تمسحه بواسطة واتساب الرقم اللي عاوزه، وهيتم حفظ الجلسة تلقائياً بعد الربط.
            </div>

            <div class="form-row">
                <div class="form-field">
                    <label>اسم الجلسة / الوصف <span class="req">*</span></label>
                    <input type="text" id="displayName" class="form-control" placeholder="مثال: رقم القاهرة الرئيسي" />
                    <div class="hint">اسم وصفي يساعدك في التعرف على الرقم لاحقاً.</div>
                </div>
                <div class="form-field">
                    <label>رقم الهاتف</label>
                    <input type="text" id="phoneNumber" class="form-control" placeholder="201001234567" dir="ltr" style="text-align:left;" />
                    <div class="hint">للعرض فقط — هيتم التعرف على الرقم تلقائياً بعد الربط.</div>
                </div>
            </div>

            <div class="form-actions">
                <a href="@Url.Action("Index")" class="ws-btn ws-btn-cancel">
                    <i class="fa fa-arrow-right"></i> رجوع
                </a>
                <button type="button" id="btnCreate" class="ws-btn ws-btn-primary">
                    <i class="fa fa-magic"></i> إنشاء جلسة و عرض QR
                </button>
            </div>
        </div>

        <!-- ====== Step 2: QR + Polling ====== -->
        <div id="stage2" style="display:none;">
            <div class="qr-section">
                <div class="qr-card">
                    <h4><i class="fa fa-qrcode"></i> امسح الـ QR من واتساب</h4>
                    <div id="qrLoading" class="qr-loading">
                        <i class="fa fa-spinner fa-spin pulse"></i>
                        <p>جاري تجهيز الـ QR Code...</p>
                    </div>
                    <div id="qrContent" style="display:none;">
                        <div class="qr-img-wrap"><img id="qrImg" src="" alt="QR Code" /></div>
                        <div class="qr-instructions">
                            افتح <strong>واتساب</strong> ← الإعدادات ← <strong>الأجهزة المرتبطة</strong> ← <strong>ربط جهاز</strong> ← امسح الكود
                        </div>
                    </div>
                </div>

                <div>
                    <div class="session-info">
                        <h4><i class="fa fa-info-circle"></i> بيانات الجلسة</h4>
                        <div class="info-row">
                            <span class="key">الاسم:</span>
                            <span class="val" id="infoName">—</span>
                        </div>
                        <div class="info-row">
                            <span class="key">رقم الهاتف:</span>
                            <span class="val" id="infoPhone">—</span>
                        </div>
                        <div class="info-row">
                            <span class="key">Session ID:</span>
                            <span class="val" id="infoSession">—</span>
                        </div>
                    </div>

                    <div class="status-card connecting" id="statusCard">
                        <i class="fa fa-spinner fa-spin status-icon"></i>
                        <div>
                            <strong id="statusTitle">في انتظار المسح...</strong>
                            <small id="statusSub">امسح الـ QR من واتساب الرقم اللي عاوز تربطه.</small>
                        </div>
                    </div>

                    <div style="margin-top: 14px; display: flex; gap: 8px; flex-wrap: wrap;">
                        <button type="button" id="btnConfirmScan" class="ws-btn ws-btn-primary" style="font-size:13px; padding:10px 18px;">
                            <i class="fa fa-check"></i> تم المسح، استكمال الحفظ
                        </button>
                        <button type="button" id="btnRefreshQr" class="ws-btn ws-btn-cancel" style="font-size:12px; padding:8px 14px;">
                            <i class="fa fa-refresh"></i> تحديث الـ QR
                        </button>
                        <button type="button" id="btnCancelStage2" class="ws-btn ws-btn-cancel" style="font-size:12px; padding:8px 14px;">
                            <i class="fa fa-times"></i> إلغاء
                        </button>
                    </div>
                    <small style="color:#94a3b8; font-size:11px; display:block; margin-top:10px;">
                        بعد ما تمسح الـ QR من واتساب، اضغط زرار "تم المسح، استكمال الحفظ" لحفظ الجلسة.
                    </small>
                </div>
            </div>
        </div>

        <!-- ====== Step 3: Done ====== -->
        <div id="stage3" style="display:none; text-align:center; padding: 30px 20px;">
            <div style="width:100px; height:100px; background: #dcfce7; border-radius: 50%; display: grid; place-items: center; margin: 0 auto 20px;">
                <i class="fa fa-check" style="font-size: 50px; color: #16a34a;"></i>
            </div>
            <h2 style="color:#16a34a; margin:0 0 10px;">تم الربط بنجاح! 🎉</h2>
            <p id="successPhone" style="color:#475569; font-size:15px; margin:0 0 24px;"></p>
            <a href="@Url.Action("Index")" class="ws-btn ws-btn-primary"><i class="fa fa-list"></i> الرجوع لقائمة الجلسات</a>
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

<script src="https://code.jquery.com/jquery-3.6.4.min.js"></script>
<script>
    jQuery(function ($) {
        var token = $('input[name="__RequestVerificationToken"]').first().val();
        var state = {
            sessionId: null,
            displayName: null,
            phoneNumber: null,
            qrPollTimer: null,
            statusPollTimer: null,
            connectedPhone: null
        };

        function showMsg(text, ok) {
            $('#formMessage').html('<div class="toast-msg ' + (ok ? 'ok' : 'err') + '">' +
                '<i class="fa fa-' + (ok ? 'check-circle' : 'times-circle') + '"></i> ' + text + '</div>');
            if (ok) setTimeout(function () { $('#formMessage').empty(); }, 3500);
        }

        function setStep(n) {
            $('.step').removeClass('active done');
            for (var i = 1; i < n; i++) $('#step' + i).addClass('done');
            $('#step' + n).addClass('active');
            $('#stage1, #stage2, #stage3').hide();
            $('#stage' + n).show();
        }

        function setStatus(state, title, sub, icon) {
            var $c = $('#statusCard').removeClass('connecting connected failed').addClass(state);
            $('#statusTitle').text(title);
            $('#statusSub').text(sub || '');
            $c.find('.status-icon').attr('class', 'fa ' + icon + ' status-icon');
        }

        // ===== Step 1 → Step 2: Create session =====
        $('#btnCreate').on('click', function () {
            var name = $('#displayName').val().trim();
            var phone = $('#phoneNumber').val().trim();
            if (!name) { showMsg('برجاء إدخال اسم الجلسة', false); return; }

            state.displayName = name;
            state.phoneNumber = phone;

            var $btn = $(this).prop('disabled', true).html('<i class="fa fa-spinner fa-spin"></i> جاري الإنشاء...');

            $.post('@Url.Action("CreateWhaStackSession", "WapilotSettings")', { name: 'Tasahel_' + name.replace(/\s+/g, '_') + '_' + Date.now() })
                .done(function (res) {
                    if (!res.success || !res.sessionId) {
                        showMsg(res.message || 'فشل إنشاء الجلسة', false);
                        return;
                    }
                    state.sessionId = res.sessionId;
                    $('#infoName').text(state.displayName);
                    $('#infoPhone').text(state.phoneNumber || '—');
                    $('#infoSession').text(state.sessionId);
                    setStep(2);
                    fetchQr();
                    startStatusPolling();
                })
                .fail(function () { showMsg('خطأ في الاتصال بـ WhaStack', false); })
                .always(function () { $btn.prop('disabled', false).html('<i class="fa fa-magic"></i> إنشاء جلسة و عرض QR'); });
        });

        // ===== QR fetch (with retry-on-pending) =====
        function fetchQr() {
            $('#qrLoading').show();
            $('#qrContent').hide();

            $.post('@Url.Action("GetWhaStackSessionQr", "WapilotSettings")', { sessionId: state.sessionId })
                .done(function (res) {
                    if (res.success && res.qrCode) {
                        var src = res.qrCode.startsWith('data:') ? res.qrCode : ('data:image/png;base64,' + res.qrCode);
                        $('#qrImg').attr('src', src);
                        $('#qrLoading').hide();
                        $('#qrContent').show();
                    } else if (res.pending) {
                        // QR not ready yet, retry after 2s
                        if (state.qrPollTimer) clearTimeout(state.qrPollTimer);
                        state.qrPollTimer = setTimeout(fetchQr, 2000);
                    } else {
                        $('#qrLoading').html('<i class="fa fa-exclamation-triangle" style="color:#dc2626;"></i><p style="color:#991b1b;">' + (res.message || 'فشل جلب QR') + '</p>');
                    }
                })
                .fail(function () {
                    $('#qrLoading').html('<i class="fa fa-times" style="color:#dc2626;"></i><p style="color:#991b1b;">خطأ في الاتصال</p>');
                });
        }

        $('#btnRefreshQr').on('click', function () {
            if (state.qrPollTimer) clearTimeout(state.qrPollTimer);
            fetchQr();
        });

        // ===== Status polling =====
        function startStatusPolling() {
            if (state.statusPollTimer) clearInterval(state.statusPollTimer);
            state.statusPollTimer = setInterval(checkStatus, 3000);
            checkStatus();
        }

        function stopPolling() {
            if (state.statusPollTimer) { clearInterval(state.statusPollTimer); state.statusPollTimer = null; }
            if (state.qrPollTimer) { clearTimeout(state.qrPollTimer); state.qrPollTimer = null; }
        }

        function checkStatus() {
            $.post('@Url.Action("GetWhaStackSessionStatus", "WapilotSettings")', { sessionId: state.sessionId })
                .done(function (res) {
                    if (!res.success) return;
                    var status = (res.status || '').toLowerCase();
                    if (status.indexOf('connect') >= 0 && status.indexOf('dis') < 0 ||
                        status === 'ready' || status === 'authenticated' || status === 'open' || status === 'active') {
                        // Connected — show as connected but DO NOT auto-save. User must click confirm button.
                        state.connectedPhone = res.phoneNumber || state.phoneNumber;
                        setStatus('connected', 'تم الربط بنجاح ✓', 'اضغط "تم المسح، استكمال الحفظ" لإكمال الإضافة.', 'fa-check-circle');
                        stopPolling();
                    } else if (status === 'qr' || status === 'scan_qr' || status === 'qrcode' || status === 'pending') {
                        setStatus('connecting', 'في انتظار المسح...', 'امسح الـ QR من واتساب الرقم اللي عاوز تربطه.', 'fa-spinner fa-spin');
                    } else if (status === 'loading' || status === 'connecting') {
                        setStatus('connecting', 'جاري الاتصال...', 'يتم التحقق من الجلسة.', 'fa-spinner fa-spin');
                    }
                });
        }

        // Manual confirm — user clicks after scanning
        $('#btnConfirmScan').on('click', function () {
            stopPolling();
            saveSession();
        });

        // ===== Save session to DB =====
        function saveSession() {
            setStatus('connecting', 'جاري حفظ الجلسة...', 'لحظات...', 'fa-spinner fa-spin');
            $.post('@Url.Action("CreateJson", "WhaStackSessions")', {
                __RequestVerificationToken: token,
                displayName: state.displayName,
                phoneNumber: state.connectedPhone || state.phoneNumber,
                sessionId: state.sessionId,
                isActive: true
            }).done(function (res) {
                if (res.success) {
                    setStatus('connected', 'تم الربط بنجاح!', 'الجلسة جاهزة للاستخدام.', 'fa-check-circle');
                    $('#successPhone').text(state.connectedPhone ? ('الرقم المربوط: ' + state.connectedPhone) : 'الجلسة جاهزة دلوقتي.');
                    setTimeout(function () { setStep(3); }, 1200);
                } else {
                    setStatus('failed', 'فشل الحفظ', res.message || 'حاول مرة أخرى.', 'fa-times-circle');
                }
            }).fail(function () {
                setStatus('failed', 'خطأ في الاتصال', 'حاول مرة أخرى.', 'fa-times-circle');
            });
        }

        $('#btnCancelStage2').on('click', function () {
            stopPolling();
            setStep(1);
        });

        // Cleanup on page leave
        window.addEventListener('beforeunload', stopPolling);
    });
</script>
