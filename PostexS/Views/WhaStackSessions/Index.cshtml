@model List<PostexS.Models.Domain.WhaStackSessionInstance>
@{
    ViewData["Title"] = "جلسات واتساب (WhaStack)";
    var totalSuccess = Model?.Sum(m => m.TotalSentSuccess) ?? 0;
    var totalFailed = Model?.Sum(m => m.TotalSentFailed) ?? 0;
    var activeCount = Model?.Count(m => m.IsActive) ?? 0;
    var totalCount = Model?.Count ?? 0;
}

<style>
    .ws-page { font-family: 'Cairo', 'Tajawal', sans-serif; padding: 24px; background: #f5f7fb; min-height: 100vh; }

    .ws-hero {
        background: linear-gradient(135deg, #25D366 0%, #128C7E 100%);
        color: #fff;
        padding: 32px 36px;
        border-radius: 18px;
        box-shadow: 0 14px 40px -12px rgba(18, 140, 126, 0.45);
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 20px;
        margin-bottom: 24px;
    }
    .ws-hero h1 { margin: 0; font-size: 26px; font-weight: 700; display: flex; align-items: center; gap: 12px; }
    .ws-hero p { margin: 8px 0 0; opacity: .92; font-size: 14px; max-width: 620px; line-height: 1.7; }
    .ws-hero .ws-btn-add {
        background: #fff; color: #128C7E; padding: 12px 24px; border-radius: 12px;
        font-weight: 700; text-decoration: none; display: inline-flex; align-items: center; gap: 8px;
        transition: all .25s; box-shadow: 0 6px 18px -6px rgba(0,0,0,.25); font-size: 15px;
    }
    .ws-hero .ws-btn-add:hover { transform: translateY(-2px); box-shadow: 0 10px 24px -6px rgba(0,0,0,.3); }

    .ws-stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 16px; margin-bottom: 24px; }
    .ws-stat {
        background: #fff; padding: 22px; border-radius: 16px;
        box-shadow: 0 4px 18px -8px rgba(15, 23, 42, .12);
        display: flex; align-items: center; gap: 16px;
        border: 1px solid #eef0f5; transition: transform .2s;
    }
    .ws-stat:hover { transform: translateY(-3px); }
    .ws-stat .icon {
        width: 56px; height: 56px; border-radius: 14px; display: grid; place-items: center;
        font-size: 24px; color: #fff; flex-shrink: 0;
    }
    .ws-stat .icon.green   { background: linear-gradient(135deg,#34d399,#10b981); }
    .ws-stat .icon.blue    { background: linear-gradient(135deg,#60a5fa,#3b82f6); }
    .ws-stat .icon.red     { background: linear-gradient(135deg,#f87171,#ef4444); }
    .ws-stat .icon.purple  { background: linear-gradient(135deg,#a78bfa,#8b5cf6); }
    .ws-stat .label { color: #64748b; font-size: 13px; margin: 0; font-weight: 500; }
    .ws-stat .value { color: #0f172a; font-size: 26px; margin: 4px 0 0; font-weight: 700; }

    .ws-info-box {
        background: #eff6ff; border-right: 4px solid #3b82f6;
        padding: 16px 20px; border-radius: 12px; margin-bottom: 22px;
        color: #1e40af; font-size: 14px; line-height: 1.8;
    }
    .ws-info-box i { color: #3b82f6; margin-left: 6px; }

    .ws-card {
        background: #fff; border-radius: 18px; padding: 26px;
        box-shadow: 0 4px 24px -10px rgba(15,23,42,.1); margin-bottom: 22px;
        border: 1px solid #eef0f5;
    }
    .ws-card-title { font-size: 18px; font-weight: 700; color: #0f172a; margin: 0 0 18px; display: flex; align-items: center; gap: 10px; }
    .ws-card-title i { color: #25D366; }

    .ws-table { width: 100%; border-collapse: separate; border-spacing: 0; }
    .ws-table thead th {
        background: #f8fafc; color: #475569; font-weight: 700; font-size: 13px;
        padding: 14px 16px; text-align: right; border-bottom: 2px solid #e2e8f0;
    }
    .ws-table thead th:first-child { border-radius: 0 12px 0 0; }
    .ws-table thead th:last-child  { border-radius: 12px 0 0 0; }
    .ws-table tbody td { padding: 16px; border-bottom: 1px solid #f1f5f9; vertical-align: middle; font-size: 14px; color: #334155; }
    .ws-table tbody tr:hover { background: #fafbfd; }
    .ws-table tbody tr:last-child td { border-bottom: none; }

    .session-name { font-weight: 700; color: #0f172a; font-size: 15px; }
    .session-meta { font-size: 12px; color: #94a3b8; margin-top: 2px; }
    .session-id-tag {
        display: inline-block; background: #f1f5f9; color: #475569;
        padding: 4px 10px; border-radius: 6px; font-family: 'Courier New', monospace;
        font-size: 12px; font-weight: 600; letter-spacing: .5px;
    }
    .phone-tag { color: #0f172a; font-weight: 600; direction: ltr; display: inline-block; }

    .badge-status {
        display: inline-flex; align-items: center; gap: 6px; padding: 6px 12px;
        border-radius: 20px; font-size: 12px; font-weight: 700;
    }
    .badge-active   { background: #dcfce7; color: #166534; }
    .badge-inactive { background: #f1f5f9; color: #64748b; }
    .badge-active .dot, .badge-inactive .dot {
        width: 8px; height: 8px; border-radius: 50%; display: inline-block;
    }
    .badge-active .dot   { background: #16a34a; box-shadow: 0 0 0 3px rgba(22,163,74,.18); animation: pulse 2s infinite; }
    .badge-inactive .dot { background: #94a3b8; }
    @@keyframes pulse {
        0%, 100% { box-shadow: 0 0 0 3px rgba(22,163,74,.18); }
        50%      { box-shadow: 0 0 0 6px rgba(22,163,74,.08); }
    }

    .stat-mini { display: inline-flex; align-items: center; gap: 4px; font-weight: 700; }
    .stat-mini.success { color: #16a34a; }
    .stat-mini.failed  { color: #dc2626; }
    .stat-divider { color: #cbd5e1; margin: 0 6px; }

    .badge-fails {
        background: #fee2e2; color: #b91c1c; padding: 4px 10px;
        border-radius: 20px; font-size: 12px; font-weight: 700;
    }
    .badge-zero { color: #cbd5e1; font-weight: 700; }

    .ws-btn {
        display: inline-flex; align-items: center; gap: 6px; padding: 7px 14px;
        border-radius: 8px; font-size: 12px; font-weight: 600; border: none;
        cursor: pointer; transition: all .2s; text-decoration: none;
    }
    .ws-btn:hover { transform: translateY(-1px); box-shadow: 0 4px 12px -4px rgba(0,0,0,.2); }
    .ws-btn-primary { background: #3b82f6; color: #fff; }
    .ws-btn-warning { background: #f59e0b; color: #fff; }
    .ws-btn-success { background: #10b981; color: #fff; }
    .ws-btn-danger  { background: #ef4444; color: #fff; }
    .actions-cell { display: flex; gap: 6px; flex-wrap: wrap; }

    .ws-empty {
        text-align: center; padding: 60px 20px; color: #94a3b8;
    }
    .ws-empty .icon-wrap {
        width: 100px; height: 100px; background: #f1f5f9; border-radius: 50%;
        display: grid; place-items: center; margin: 0 auto 20px; font-size: 40px; color: #cbd5e1;
    }
    .ws-empty h3 { color: #475569; font-weight: 700; margin: 0 0 8px; }
    .ws-empty p { margin: 0 0 20px; }

    .test-section { background: linear-gradient(135deg, #f0fdf4 0%, #ecfeff 100%); border: 1px solid #d1fae5; }
    .test-row { display: grid; grid-template-columns: 1fr 2fr auto; gap: 12px; align-items: end; }
    .test-row label { display:block; font-size: 13px; font-weight: 600; color: #475569; margin-bottom: 6px; }
    .test-row .form-control {
        width: 100%; padding: 11px 14px; border-radius: 10px;
        border: 1.5px solid #d1fae5; background: #fff; font-size: 14px;
        transition: all .2s; font-family: inherit;
    }
    .test-row .form-control:focus {
        outline: none; border-color: #25D366; box-shadow: 0 0 0 3px rgba(37,211,102,.15);
    }
    .test-row .ws-btn-test {
        background: linear-gradient(135deg,#25D366,#128C7E); color:#fff;
        padding: 11px 22px; border-radius: 10px; border: none;
        font-weight: 700; cursor: pointer; transition: all .25s; font-size: 14px;
        display: inline-flex; align-items: center; gap: 8px;
    }
    .test-row .ws-btn-test:hover { transform: translateY(-2px); box-shadow: 0 8px 20px -6px rgba(18,140,126,.5); }
    .test-row .ws-btn-test:disabled { opacity: .6; transform: none; cursor: not-allowed; }

    .ws-alert { padding: 14px 18px; border-radius: 12px; margin-bottom: 20px; display: flex; align-items: center; gap: 10px; font-weight: 600; animation: slideDown .3s ease; }
    .ws-alert-success { background: #dcfce7; color: #166534; border-right: 4px solid #16a34a; }
    .ws-alert-danger  { background: #fee2e2; color: #991b1b; border-right: 4px solid #dc2626; }
    .ws-alert button { margin-right: auto; background: none; border: none; cursor: pointer; opacity: .6; font-size: 18px; }
    @@keyframes slideDown { from { opacity: 0; transform: translateY(-10px); } to { opacity: 1; transform: translateY(0); } }

    @@media (max-width: 768px) {
        .test-row { grid-template-columns: 1fr; }
        .ws-table { font-size: 13px; }
        .ws-table thead th, .ws-table tbody td { padding: 10px 8px; }
    }
</style>

<div class="ws-page">

    <!-- Hero -->
    <div class="ws-hero">
        <div>
            <h1><i class="fa fa-whatsapp"></i> @ViewData["Title"]</h1>
            <p>إدارة جلسات أرقام الواتساب المتعددة. النظام يوزّع الرسائل تلقائياً على الأرقام بشكل متوازن لتجنب الحظر، ولو فشل أي رقم يُعاد المحاولة بالباقي.</p>
        </div>
        <a href="@Url.Action("Create")" class="ws-btn-add">
            <i class="fa fa-plus-circle"></i> إضافة جلسة جديدة
        </a>
    </div>

    <!-- Alerts -->
    @if (TempData["Success"] != null)
    {
        <div class="ws-alert ws-alert-success">
            <i class="fa fa-check-circle"></i> @TempData["Success"]
            <button type="button" onclick="this.parentElement.remove()">×</button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="ws-alert ws-alert-danger">
            <i class="fa fa-times-circle"></i> @TempData["Error"]
            <button type="button" onclick="this.parentElement.remove()">×</button>
        </div>
    }

    <!-- Stats -->
    <div class="ws-stats">
        <div class="ws-stat">
            <div class="icon purple"><i class="fa fa-mobile"></i></div>
            <div>
                <p class="label">إجمالي الجلسات</p>
                <p class="value">@totalCount</p>
            </div>
        </div>
        <div class="ws-stat">
            <div class="icon blue"><i class="fa fa-bolt"></i></div>
            <div>
                <p class="label">الجلسات المفعلة</p>
                <p class="value">@activeCount</p>
            </div>
        </div>
        <div class="ws-stat">
            <div class="icon green"><i class="fa fa-check"></i></div>
            <div>
                <p class="label">إجمالي الرسائل الناجحة</p>
                <p class="value">@totalSuccess.ToString("N0")</p>
            </div>
        </div>
        <div class="ws-stat">
            <div class="icon red"><i class="fa fa-exclamation-triangle"></i></div>
            <div>
                <p class="label">إجمالي الرسائل الفاشلة</p>
                <p class="value">@totalFailed.ToString("N0")</p>
            </div>
        </div>
    </div>

    <div class="ws-info-box">
        <i class="fa fa-info-circle"></i>
        <strong>كيف يعمل التوزيع؟</strong>
        عند إرسال رسالة، يختار النظام تلقائياً الجلسة الأقل استخداماً خلال آخر 24 ساعة لتحقيق التوازن وتجنّب الحظر.
        لو فشلت أي جلسة في الإرسال، يتم تجربة الجلسة التالية تلقائياً حتى تتم الرسالة بنجاح.
    </div>

    <!-- Sessions Table -->
    <div class="ws-card">
        <h3 class="ws-card-title"><i class="fa fa-list"></i> الجلسات المسجلة</h3>

        @if (Model == null || Model.Count == 0)
        {
            <div class="ws-empty">
                <div class="icon-wrap"><i class="fa fa-mobile"></i></div>
                <h3>لا توجد جلسات بعد</h3>
                <p>ابدأ بإضافة أول جلسة واتساب من Session ID الموجود لديك على لوحة WhaStack.</p>
                <a href="@Url.Action("Create")" class="ws-btn ws-btn-success" style="padding:10px 20px; font-size:14px;">
                    <i class="fa fa-plus"></i> إضافة أول جلسة
                </a>
            </div>
        }
        else
        {
            <div style="overflow-x:auto;">
                <table class="ws-table">
                    <thead>
                        <tr>
                            <th style="width:50px;">#</th>
                            <th>الجلسة</th>
                            <th>رقم الهاتف</th>
                            <th>Session ID</th>
                            <th>الحالة</th>
                            <th>آخر استخدام</th>
                            <th>إحصائيات</th>
                            <th>فشل متتالي</th>
                            <th style="width:240px;">إجراءات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int i = 1; }
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td><strong style="color:#94a3b8;">@(i++)</strong></td>
                                <td>
                                    <div class="session-name">@item.DisplayName</div>
                                    @if (item.CreateOn != default)
                                    {
                                        <div class="session-meta">أُضيفت في @item.CreateOn.ToLocalTime().ToString("yyyy-MM-dd")</div>
                                    }
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.PhoneNumber))
                                    {
                                        <span class="phone-tag">@item.PhoneNumber</span>
                                    }
                                    else
                                    {
                                        <span style="color:#cbd5e1;">—</span>
                                    }
                                </td>
                                <td><span class="session-id-tag">@item.SessionId</span></td>
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge-status badge-active"><span class="dot"></span> مفعل</span>
                                    }
                                    else
                                    {
                                        <span class="badge-status badge-inactive"><span class="dot"></span> معطل</span>
                                    }
                                </td>
                                <td>
                                    @if (item.LastUsedAt.HasValue)
                                    {
                                        <span style="color:#475569;">@item.LastUsedAt.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</span>
                                    }
                                    else
                                    {
                                        <span style="color:#cbd5e1;">لم تُستخدم بعد</span>
                                    }
                                </td>
                                <td>
                                    <span class="stat-mini success"><i class="fa fa-check"></i> @item.TotalSentSuccess</span>
                                    <span class="stat-divider">|</span>
                                    <span class="stat-mini failed"><i class="fa fa-times"></i> @item.TotalSentFailed</span>
                                </td>
                                <td>
                                    @if (item.ConsecutiveFailures > 0)
                                    {
                                        <span class="badge-fails">@item.ConsecutiveFailures</span>
                                    }
                                    else
                                    {
                                        <span class="badge-zero">0</span>
                                    }
                                </td>
                                <td>
                                    <div class="actions-cell">
                                        <a href="@Url.Action("Edit", new { id = item.Id })" class="ws-btn ws-btn-primary">
                                            <i class="fa fa-edit"></i> تعديل
                                        </a>
                                        <form asp-action="ToggleActive" method="post" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="submit" class="ws-btn @(item.IsActive ? "ws-btn-warning" : "ws-btn-success")">
                                                <i class="fa @(item.IsActive ? "fa-pause" : "fa-play")"></i>
                                                @(item.IsActive ? "تعطيل" : "تفعيل")
                                            </button>
                                        </form>
                                        <form asp-action="Delete" method="post" style="display:inline;" class="form-delete">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="submit" class="ws-btn ws-btn-danger">
                                                <i class="fa fa-trash"></i> حذف
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

    <!-- Test Send Section -->
    <div class="ws-card test-section">
        <h3 class="ws-card-title"><i class="fa fa-paper-plane"></i> اختبار الإرسال</h3>

        <div style="display:flex; gap:12px; margin-bottom:14px; flex-wrap:wrap;">
            <div style="flex:1; min-width:240px;">
                <label style="display:block; font-size:13px; font-weight:700; color:#475569; margin-bottom:6px;">
                    <i class="fa fa-mobile"></i> اختر الجلسة (الرقم اللي هتُرسل منه)
                </label>
                <select id="testSession" class="form-control" style="padding:11px 14px; border-radius:10px; border:1.5px solid #d1fae5; font-size:14px;">
                    <option value="">— اختر جلسة —</option>
                    @if (Model != null)
                    {
                        @foreach (var s in Model.Where(x => x.IsActive))
                        {
                            <option value="@s.Id">@s.DisplayName @(string.IsNullOrEmpty(s.PhoneNumber) ? "" : $"({s.PhoneNumber})")</option>
                        }
                    }
                </select>
            </div>
            <div style="min-width:200px;">
                <label style="display:block; font-size:13px; font-weight:700; color:#475569; margin-bottom:6px;">نوع الإرسال</label>
                <div style="display:flex; gap:6px;">
                    <button type="button" class="send-mode-btn active" data-mode="phone" style="flex:1; padding:11px; border-radius:10px; border:1.5px solid #d1fae5; background:#fff; cursor:pointer; font-weight:600; font-size:13px;">
                        <i class="fa fa-user"></i> لرقم
                    </button>
                    <button type="button" class="send-mode-btn" data-mode="group" style="flex:1; padding:11px; border-radius:10px; border:1.5px solid #d1fae5; background:#fff; cursor:pointer; font-weight:600; font-size:13px;">
                        <i class="fa fa-users"></i> لجروب
                    </button>
                </div>
            </div>
        </div>

        <!-- Phone target -->
        <div id="targetPhone" style="margin-bottom:12px;">
            <label style="display:block; font-size:13px; font-weight:700; color:#475569; margin-bottom:6px;">رقم الهاتف (مع كود الدولة)</label>
            <input type="text" id="testPhone" class="form-control" placeholder="201001234567" autocomplete="off"
                   style="padding:11px 14px; border-radius:10px; border:1.5px solid #d1fae5; font-size:14px; width:100%;" />
        </div>

        <!-- Group target -->
        <div id="targetGroup" style="margin-bottom:12px; display:none;">
            <label style="display:block; font-size:13px; font-weight:700; color:#475569; margin-bottom:6px;">جروب</label>
            <div style="display:flex; gap:8px;">
                <select id="testGroup" class="form-control" style="flex:1; padding:11px 14px; border-radius:10px; border:1.5px solid #d1fae5; font-size:14px;">
                    <option value="">— اختر الجلسة أولاً ثم اضغط جلب الجروبات —</option>
                </select>
                <button type="button" id="btnFetchGroups" class="ws-btn ws-btn-primary" style="font-size:13px; padding:11px 16px;">
                    <i class="fa fa-refresh"></i> جلب الجروبات
                </button>
            </div>
            <small style="color:#94a3b8; font-size:11px; display:block; margin-top:4px;">يجب اختيار الجلسة أولاً ليتم جلب الجروبات الخاصة بها.</small>
        </div>

        <div style="margin-bottom:14px;">
            <label style="display:block; font-size:13px; font-weight:700; color:#475569; margin-bottom:6px;">نص الرسالة</label>
            <textarea id="testMessage" class="form-control" rows="3" placeholder="اكتب رسالة تجريبية..."
                      style="width:100%; padding:11px 14px; border-radius:10px; border:1.5px solid #d1fae5; font-size:14px; font-family:inherit; resize:vertical;"></textarea>
        </div>

        <button id="btnSendTest" class="ws-btn-test">
            <i class="fa fa-send"></i> إرسال
        </button>
        <div id="testResult" style="margin-top:14px;"></div>
    </div>

</div>

<style>
    .send-mode-btn.active { background: linear-gradient(135deg,#25D366,#128C7E) !important; color:#fff !important; border-color:#128C7E !important; }
</style>

@section Scripts {
    @Html.AntiForgeryToken()
    <script src="https://code.jquery.com/jquery-3.6.4.min.js"></script>
    <script>
        jQuery(function ($) {
            // Beautiful delete confirmation
            $('.form-delete').on('submit', function (e) {
                e.preventDefault();
                var $form = $(this);
                if (typeof swal === 'function') {
                    swal({
                        title: 'تأكيد الحذف',
                        text: 'هل أنت متأكد من حذف هذه الجلسة؟ لا يمكن التراجع.',
                        icon: 'warning',
                        buttons: ['إلغاء', 'نعم، احذف'],
                        dangerMode: true
                    }).then(function (ok) { if (ok) $form.off('submit').submit(); });
                } else if (confirm('متأكد من حذف هذه الجلسة؟')) {
                    $form.off('submit').submit();
                }
            });

            var sendMode = 'phone';
            var token = $('input[name=__RequestVerificationToken]').first().val();

            // Mode toggle
            $('.send-mode-btn').on('click', function () {
                $('.send-mode-btn').removeClass('active');
                $(this).addClass('active');
                sendMode = $(this).data('mode');
                if (sendMode === 'phone') { $('#targetPhone').show(); $('#targetGroup').hide(); }
                else { $('#targetPhone').hide(); $('#targetGroup').show(); }
            });

            // Fetch groups for selected session
            $('#btnFetchGroups').on('click', function () {
                var sid = $('#testSession').val();
                if (!sid) { alert('برجاء اختيار جلسة أولاً'); return; }
                var $btn = $(this).prop('disabled', true).html('<i class="fa fa-spinner fa-spin"></i> جاري...');
                $('#testGroup').html('<option>جاري التحميل...</option>');
                $.post('@Url.Action("GetGroupsForSession")', { __RequestVerificationToken: token, sessionInstanceId: sid })
                    .done(function (res) {
                        if (!res.success || !res.groups || res.groups.length === 0) {
                            $('#testGroup').html('<option value="">' + (res.message || 'لا توجد جروبات') + '</option>');
                        } else {
                            var opts = '<option value="">— اختر جروب (' + res.count + ' متاح) —</option>';
                            res.groups.forEach(function (g) {
                                opts += '<option value="' + g.id + '">' + (g.name || g.id) + '</option>';
                            });
                            $('#testGroup').html(opts);
                        }
                    })
                    .fail(function () { $('#testGroup').html('<option value="">فشل الاتصال</option>'); })
                    .always(function () { $btn.prop('disabled', false).html('<i class="fa fa-refresh"></i> جلب الجروبات'); });
            });

            // Test send (per-session, supports phone or group)
            $('#btnSendTest').on('click', function () {
                var $btn = $(this);
                var sid = $('#testSession').val();
                var msg = $('#testMessage').val().trim();
                if (!sid) {
                    $('#testResult').html('<div class="ws-alert ws-alert-danger"><i class="fa fa-exclamation-triangle"></i> برجاء اختيار الجلسة.</div>');
                    return;
                }
                var target = sendMode === 'phone' ? $('#testPhone').val().trim() : $('#testGroup').val();
                if (!target || !msg) {
                    $('#testResult').html('<div class="ws-alert ws-alert-danger"><i class="fa fa-exclamation-triangle"></i> برجاء إدخال ' + (sendMode === 'phone' ? 'رقم الهاتف' : 'اختيار الجروب') + ' ونص الرسالة.</div>');
                    return;
                }
                $btn.prop('disabled', true).html('<i class="fa fa-spinner fa-spin"></i> جاري الإرسال...');
                $('#testResult').html('');
                $.post('@Url.Action("SendTestFromSession")', {
                    __RequestVerificationToken: token,
                    sessionInstanceId: sid,
                    phoneNumber: target,
                    message: msg,
                    isGroup: sendMode === 'group'
                }).done(function (res) {
                    var cls = res.success ? 'ws-alert-success' : 'ws-alert-danger';
                    var icon = res.success ? 'fa-check-circle' : 'fa-times-circle';
                    $('#testResult').html('<div class="ws-alert ' + cls + '"><i class="fa ' + icon + '"></i> ' + res.message + '</div>');
                    if (res.success) setTimeout(function () { location.reload(); }, 1800);
                }).fail(function (xhr) {
                    $('#testResult').html('<div class="ws-alert ws-alert-danger"><i class="fa fa-times-circle"></i> خطأ في الاتصال: ' + xhr.statusText + '</div>');
                }).always(function () {
                    $btn.prop('disabled', false).html('<i class="fa fa-send"></i> إرسال');
                });
            });
        });
    </script>
}
